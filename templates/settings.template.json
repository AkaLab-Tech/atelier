{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": ["<worktree>", "<worktree>-worktrees"],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",

      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push * develop)",
      "Bash(git push * staging)",
      "Bash(git reset --hard*)",
      "Bash(git config --global*)",

      "Bash(gh auth logout*)",
      "Bash(gh auth refresh*)",
      "Bash(gh repo delete*)",
      "Bash(gh api -X POST*)",
      "Bash(gh api -X PATCH*)",
      "Bash(gh api -X DELETE*)",

      "Bash(pnpm publish*)",
      "Bash(npm publish*)",

      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",

      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",

      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.ssh/**)",

      "Edit(./.github/workflows/**)",
      "Edit(<worktree>/.github/workflows/**)",
      "Edit(<worktree>-worktrees/**/.github/workflows/**)",
      "Write(./.github/workflows/**)",
      "Write(<worktree>/.github/workflows/**)",
      "Write(<worktree>-worktrees/**/.github/workflows/**)",

      "Edit(./package.json)",
      "Edit(<worktree>/package.json)",
      "Edit(<worktree>-worktrees/**/package.json)",
      "Write(./package.json)",
      "Write(<worktree>/package.json)",
      "Write(<worktree>-worktrees/**/package.json)",

      "Edit(./pnpm-lock.yaml)",
      "Edit(<worktree>/pnpm-lock.yaml)",
      "Edit(<worktree>-worktrees/**/pnpm-lock.yaml)",
      "Write(./pnpm-lock.yaml)",
      "Write(<worktree>/pnpm-lock.yaml)",
      "Write(<worktree>-worktrees/**/pnpm-lock.yaml)"
    ],

    "ask": [
      "Edit(./.env*)",
      "Edit(<worktree>/.env*)",
      "Edit(<worktree>-worktrees/**/.env*)",
      "Write(./.env*)",
      "Write(<worktree>/.env*)",
      "Write(<worktree>-worktrees/**/.env*)",

      "Edit(./Dockerfile)",
      "Edit(<worktree>/Dockerfile)",
      "Edit(<worktree>-worktrees/**/Dockerfile)",
      "Write(./Dockerfile)",
      "Write(<worktree>/Dockerfile)",
      "Write(<worktree>-worktrees/**/Dockerfile)",

      "Edit(./docker-compose*)",
      "Edit(<worktree>/docker-compose*)",
      "Edit(<worktree>-worktrees/**/docker-compose*)",
      "Write(./docker-compose*)",
      "Write(<worktree>/docker-compose*)",
      "Write(<worktree>-worktrees/**/docker-compose*)",

      "Bash(gh pr close*)"
    ],

    "allow": [
      "Read(<worktree>/**)",
      "Read(<worktree>-worktrees/**)",
      "Glob",
      "Grep",
      "Edit(<worktree>/**)",
      "Edit(<worktree>-worktrees/**)",
      "Write(<worktree>/**)",
      "Write(<worktree>-worktrees/**)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(git fetch*)",
      "Bash(git ls-files*)",

      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b *)",
      "Bash(git switch*)",
      "Bash(git worktree*)",
      "Bash(git stash*)",

      "Bash(git push origin task/*)",

      "Bash(gh issue *)",
      "Bash(gh label list*)",
      "Bash(gh label create*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr review*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr merge*)",
      "Bash(gh project *)",
      "Bash(gh repo clone*)",
      "Bash(gh repo view*)",
      "Bash(gh gist create*)",
      "Bash(gh gist view*)",

      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm remove*)",
      "Bash(pnpm update*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm exec eslint*)",
      "Bash(pnpm exec prettier*)",
      "Bash(pnpm exec tsc*)",
      "Bash(pnpm exec vitest*)",
      "Bash(pnpm exec jest*)",
      "Bash(pnpm exec playwright*)",
      "Bash(pnpm exec tsx*)",
      "Bash(pnpm audit*)",
      "Bash(pnpm view*)",

      "Bash(vitest*)",
      "Bash(jest*)",
      "Bash(pytest*)",
      "Bash(playwright test*)",
      "Bash(eslint*)",
      "Bash(prettier*)",
      "Bash(tsc*)",
      "Bash(biome*)",

      "Bash(ls*)",
      "Bash(mkdir -p*)",
      "Bash(mv*)",
      "Bash(cp*)",

      "Bash(atelier-setup-project:*)",

      "Bash(claude plugin list --json)",
      "Bash(gh api repos/AkaLab-Tech/atelier/releases/latest*)",
      "Bash(gh api repos/AkaLab-Tech/atelier/tags*)",
      "Bash(gh api repos/AkaLab-Tech/claude-roadmap-tools/releases/latest*)",
      "Bash(gh api repos/AkaLab-Tech/claude-roadmap-tools/tags*)",
      "Bash(gh api repos/Miguelslo27/git-wt/commits/main*)",
      "Bash(command -v git-wt)",
      "Read(~/.local/state/atelier/git-wt.sha)",
      "Read(~/.claude-work/settings.json)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.claude-work/projects.json)"
    ]
  }
}
