#!/usr/bin/env bash
#
# atelier-list-projects — show every project registered in
# $ATELIER_CONFIG_DIR/projects.json, with an at-a-glance status of
# whether the on-disk setup matches the registry.
#
# Default mode (human-facing):
#   Atelier-managed projects (3):
#
#     /Users/mike/Work/storefront
#       name: storefront · version: 0.6.7 · since: 2026-05-28T18:34Z
#       status: ✓ configured
#
#     /Users/mike/Work/some-other
#       name: some-other · version: 0.6.2 · since: 2026-05-20T10:11Z
#       status: ⚠ partial (.atelier.json missing — re-run setup-project)
#
# --json mode:
#   Emits the raw projects.json content (jq-friendly) plus a per-project
#   `status` field computed from the on-disk check.
#
# --quiet mode:
#   One absolute path per line, no metadata. Useful for piping into
#   xargs / loops.
#
# Usage:
#   atelier-list-projects [--json|--quiet]
#   atelier-list-projects --help
#
# Exit codes:
#   0  zero or more projects listed successfully
#   1  unrecoverable error (missing config dir, malformed JSON, jq missing)

set -euo pipefail
IFS=$'\n\t'

VERSION="0.1.0"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

# ---------- logging ----------
die() { printf '!!  ERROR: %s\n' "$*" >&2; exit 1; }

# ---------- usage ----------
usage() {
  cat <<EOF
${SCRIPT_NAME} ${VERSION}

List atelier-managed projects from \$ATELIER_CONFIG_DIR/projects.json,
with a per-project on-disk status indicator.

USAGE:
  ${SCRIPT_NAME} [--json|--quiet]
  ${SCRIPT_NAME} --help

OPTIONS:
  --json     Emit machine-readable JSON. Each project gains a \`status\`
             field: "configured" | "partial" | "missing-directory" |
             "missing-files".
  --quiet    Emit one absolute path per line. Suitable for piping.
  --help, -h Show this help and exit.

EXIT CODES:
  0  listed successfully (even when zero projects are registered)
  1  unrecoverable error (no config dir / malformed JSON / jq missing)
EOF
}

# ---------- arg parse ----------
MODE="default"
while [ $# -gt 0 ]; do
  case "$1" in
    --json)    MODE="json"; shift ;;
    --quiet)   MODE="quiet"; shift ;;
    --help|-h) usage; exit 0 ;;
    *) die "unknown arg: $1 (run --help for usage)" ;;
  esac
done

# ---------- config + deps ----------
ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
CONFIG_FILE="$ATELIER_CONFIG_DIR/projects.json"

command -v jq >/dev/null 2>&1 || die "jq not found in PATH"

if [ ! -f "$CONFIG_FILE" ]; then
  die "$CONFIG_FILE not found — atelier may not be installed (run install.sh)"
fi

jq empty "$CONFIG_FILE" >/dev/null 2>&1 \
  || die "$CONFIG_FILE is not valid JSON"

# ---------- presentation (default mode only) ----------
# Colors are gated on a TTY + absence of NO_COLOR (repo convention). They are
# NEVER emitted in --json / --quiet, which stay machine-clean.
if [ "$MODE" = "default" ] && [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_CYAN=$'\033[36m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''; C_GREEN=''; C_YELLOW=''; C_RED=''; C_CYAN=''
fi

WORKSPACES_FILE="$ATELIER_CONFIG_DIR/workspaces.json"

# Installed atelier version (best-effort) for drift hints — resolved from the
# plugin root this script lives in (via the symlink chain). Empty if unresolved.
installed_version() {
  local self="${BASH_SOURCE[0]}" d cand
  while [ -L "$self" ]; do
    d="$(cd -P "$(dirname "$self")" && pwd)"; self="$(readlink "$self")"
    case "$self" in /*) ;; *) self="$d/$self" ;; esac
  done
  d="$(cd -P "$(dirname "$self")" && pwd)"
  for cand in "${ATELIER_PLUGIN_ROOT:-}" "$(dirname "$d")"; do
    [ -n "$cand" ] || continue
    if [ -f "$cand/.claude-plugin/plugin.json" ]; then
      jq -r '.version // empty' "$cand/.claude-plugin/plugin.json" 2>/dev/null
      return
    fi
  done
}

# older_than A B → true if semver A is strictly older than B (pure bash, no
# `sort -V` so it stays portable to BSD/macOS). Non-numeric suffixes ignored.
older_than() {
  [ -n "$1" ] && [ -n "$2" ] && [ "$1" != "$2" ] || return 1
  local IFS='.' a b i x y
  a=($1); b=($2)
  for i in 0 1 2; do
    x="${a[$i]:-0}"; y="${b[$i]:-0}"
    x="${x%%[!0-9]*}"; y="${y%%[!0-9]*}"
    [ "${x:-0}" -lt "${y:-0}" ] && return 0
    [ "${x:-0}" -gt "${y:-0}" ] && return 1
  done
  return 1
}

# workspace_of PATH → "slug<TAB>root" | "slug<TAB>member" | "" (best-effort)
workspace_of() {
  [ -f "$WORKSPACES_FILE" ] || return 0
  jq -r --arg p "$1" '
    .workspaces // {} | to_entries[]
    | if .value.root == $p then "\(.key)\troot"
      elif any(.value.members[]?; .path == $p) then "\(.key)\tmember"
      else empty end' "$WORKSPACES_FILE" 2>/dev/null | head -n1
}
CURRENT_VERSION="$(installed_version || true)"

# ---------- compute per-project on-disk status ----------
# Returns one of:
#   "configured"         — directory present and both atelier-managed files
#                          (.claude/settings.json + .atelier.json) exist
#   "partial"            — directory present but one or both files missing
#                          (likely cause: setup-project was interrupted,
#                          or the operator removed a file by hand)
#   "missing-directory"  — the registered path no longer exists on disk
#                          (operator deleted / moved the project but did not
#                          unregister; atelier-remove-project would fix)
compute_status() {
  local path="$1"
  [ -d "$path" ] || { printf 'missing-directory'; return; }
  if [ -f "$path/.claude/settings.json" ] && [ -f "$path/.atelier.json" ]; then
    printf 'configured'
  elif [ -f "$path/.claude/settings.json" ] || [ -f "$path/.atelier.json" ]; then
    printf 'partial'
  else
    printf 'missing-files'
  fi
}

# Extract the keys (paths) in their original insertion order so the output
# is deterministic. Use a while-read loop instead of `mapfile` so the
# script stays portable to bash 3.2 (macOS system bash).
PATHS=()
while IFS= read -r p; do
  [ -n "$p" ] && PATHS+=("$p")
done < <(jq -r '.projects | keys[]' "$CONFIG_FILE" 2>/dev/null)
PROJECT_COUNT="${#PATHS[@]}"

# ---------- emit ----------
case "$MODE" in
  quiet)
    for p in ${PATHS[@]+"${PATHS[@]}"}; do printf '%s\n' "$p"; done
    ;;

  json)
    # Re-emit projects.json with a `status` field merged into each entry.
    # We compute status in bash (compute_status reads the filesystem) and
    # feed the result into jq via --arg.
    {
      printf '{\n  "projects": {\n'
      local_first=true
      for p in ${PATHS[@]+"${PATHS[@]}"}; do
        s="$(compute_status "$p")"
        if $local_first; then local_first=false; else printf ',\n'; fi
        # Print the entry verbatim from the registry plus the new status field.
        entry="$(jq -c --arg p "$p" --arg s "$s" \
          '.projects[$p] + {status: $s}' "$CONFIG_FILE")"
        printf '    %s: %s' "$(jq -n --arg p "$p" '$p')" "$entry"
      done
      printf '\n  }\n}\n'
    }
    ;;

  default|*)
    if [ "$PROJECT_COUNT" -eq 0 ]; then
      printf 'No atelier-managed projects registered.\n'
      # shellcheck disable=SC2016
      printf 'Use `atelier-setup-project <path>` to register one.\n'
      exit 0
    fi

    # Header + installed-version banner.
    printf '%sAtelier-managed projects (%d)%s' "$C_BOLD" "$PROJECT_COUNT" "$C_RESET"
    [ -n "$CURRENT_VERSION" ] && printf '   %s·   atelier %s installed%s' "$C_DIM" "$CURRENT_VERSION" "$C_RESET"
    printf '\n'

    # Workspaces overview (one-liner: slug + member count).
    if [ -f "$WORKSPACES_FILE" ]; then
      ws_summary="$(jq -r '.workspaces // {} | to_entries[] | "\(.key) (\(.value.members | length))"' "$WORKSPACES_FILE" 2>/dev/null | paste -sd '·' - | sed 's/·/ · /g')"
      [ -n "$ws_summary" ] && printf '%sWorkspaces:%s %s\n' "$C_CYAN" "$C_RESET" "$ws_summary"
    fi
    printf '\n'

    drift_n=0
    for p in ${PATHS[@]+"${PATHS[@]}"}; do
      name="$(jq -r --arg p "$p" '.projects[$p].name // "(unnamed)"' "$CONFIG_FILE")"
      version="$(jq -r --arg p "$p" '.projects[$p].setupVersion // "?"' "$CONFIG_FILE")"
      since="$(jq -r --arg p "$p" '.projects[$p].setupCompleted // "?"' "$CONFIG_FILE")"
      status="$(compute_status "$p")"

      # Workspace membership label.
      ws="$(workspace_of "$p" || true)"
      if [ -n "$ws" ]; then
        ws_slug="${ws%%$'\t'*}"; ws_role="${ws##*$'\t'}"
        [ "$ws_role" = "root" ] && wslabel="workspace root: ${ws_slug}" || wslabel="workspace: ${ws_slug}"
      else
        wslabel="standalone"
      fi

      # Status glyph + colour + detail + a suggested fix command.
      suggest=""
      case "$status" in
        configured)        gcol="$C_GREEN"; glyph='✓'; detail='configured' ;;
        partial)
          gcol="$C_YELLOW"; glyph='⚠'
          missing=()
          [ -f "$p/.claude/settings.json" ] || missing+=('.claude/settings.json')
          [ -f "$p/.atelier.json" ]        || missing+=('.atelier.json')
          detail="partial (${missing[*]} missing)"
          suggest="re-run /atelier:setup-project in this dir to restore it"
          ;;
        missing-files)
          gcol="$C_YELLOW"; glyph='⚠'; detail='partial (both atelier files missing)'
          suggest="re-run /atelier:setup-project in this dir to restore it"
          ;;
        missing-directory)
          gcol="$C_RED"; glyph='✗'; detail='directory no longer exists'
          suggest="atelier-remove-project '$p' to unregister"
          ;;
        *) gcol=""; glyph='?'; detail="$status" ;;
      esac

      # Version drift vs installed.
      vcol=""; drift_note=""
      if older_than "$version" "$CURRENT_VERSION"; then
        vcol="$C_YELLOW"; drift_n=$((drift_n + 1))
        drift_note="set up with v${version}, installed is v${CURRENT_VERSION} — re-run /atelier:setup-project to resync"
      fi

      printf '  %s%s%s\n' "$C_BOLD" "$p" "$C_RESET"
      printf '    %s · v%s%s%s · %s%s%s · since %s\n' \
        "$name" "$vcol" "$version" "$C_RESET" "$C_DIM" "$wslabel" "$C_RESET" "${since%%T*}"
      printf '    %s%s %s%s\n' "$gcol" "$glyph" "$detail" "$C_RESET"
      [ -n "$drift_note" ] && printf '    %s↻ %s%s\n' "$C_YELLOW" "$drift_note" "$C_RESET"
      [ -n "$suggest" ]    && printf '    %s→ %s%s\n' "$C_DIM" "$suggest" "$C_RESET"
      printf '\n'
    done

    # Footer: suggested commands.
    printf '%sSuggested:%s\n' "$C_BOLD" "$C_RESET"
    printf '  %s•%s atelier-doctor                         %shealth check%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$C_RESET"
    if [ -f "$WORKSPACES_FILE" ]; then
      ws_list="$(jq -r '.workspaces // {} | keys | join(", ")' "$WORKSPACES_FILE" 2>/dev/null)"
      [ -n "$ws_list" ] && printf '  %s•%s atelier-workspace-status <slug>        %sper-workspace status (%s)%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$ws_list" "$C_RESET"
      [ -n "$ws_list" ] && printf '  %s•%s /atelier:onboard-workspace <slug>      %sadopt non-§5 roadmaps from the root%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$C_RESET"
    fi
    [ "$drift_n" -gt 0 ] && printf '  %s•%s /atelier:setup-project (per project)   %sresync the %d project(s) marked ↻%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$drift_n" "$C_RESET"
    ;;
esac
