#!/usr/bin/env bash
#
# atelier-doctor — health check binary for atelier (M7.1.F23).
#
# Previously implemented as the body of commands/doctor.md (a Claude Code
# slash command with per-check Bash invocations). That approach kept
# surfacing different Claude Code permission gates — file-read path-scope
# (F16/F16b), expansion warnings (F20), env-prefix mismatch (F20),
# false-positive drift (F21), shell-operator safety gate (F22). After five
# narrative-level patches we cut the loop: move ALL check logic into this
# bash binary. The slash command now just runs `atelier-doctor` (one
# allowlisted call), receives the formatted report on stdout, and passes
# it through to the operator verbatim. Compound shell operators happen
# INSIDE this script, never reaching Claude Code's permission heuristics.
#
# Usage:
#   atelier-doctor             # run all checks, print human-readable report
#   atelier-doctor --fix       # run all checks, then auto-execute the
#                                runnable pending fixes (M7.1.F30). Manual
#                                fixes (paths, re-run install.sh, etc.)
#                                still print as instructions.
#   atelier-doctor --help      # show help
#
# Exit code:
#   0   all checks ✓ (or only ↷ skipped); with --fix, also: all runnable
#       fixes applied successfully and the post-fix re-check would be clean
#   1   one or more checks ✗ (or, with --fix, one or more fix commands
#       returned non-zero)
#   2   unrecoverable error before the report could be produced
#
# Output format mirrors the legacy slash-command report:
#   atelier /doctor — health check
#
#   Plugins (compared against AkaLab-Tech/claude-plugins marketplace)
#       ✓ atelier <version>
#       ✗ claude-roadmap-tools <local> → <upstream>
#
#   External tooling
#       ✓ git-wt <short-sha>
#
#   Host checks
#       ✓ no legacy atelier hooks in ~/.claude/settings.json
#       ✗ ...
#
#   To apply pending fixes, run:
#       <copy-pasteable command block>

set -uo pipefail
# Note: no `set -e` — individual checks may fail and we must keep running.

# ---------- arg parse ----------

RUN_FIXES=false
while [ $# -gt 0 ]; do
  case "$1" in
    --fix) RUN_FIXES=true; shift ;;
    --help|-h)
      cat <<EOF
atelier-doctor — health check for atelier

USAGE:
  atelier-doctor          run all checks and print the report
  atelier-doctor --fix    after the report, auto-execute the runnable
                          pending fixes (M7.1.F30). Manual fixes still
                          print as instructions for the operator.
  atelier-doctor --help   show this help

EXIT CODES:
  0   all checks ✓ (or only ↷ skipped); with --fix, all runnable fixes
      also applied successfully
  1   one or more checks ✗ (or, with --fix, one or more fix commands
      returned non-zero)
  2   unrecoverable error before the report could be produced
EOF
      exit 0 ;;
    *) printf '!! unknown arg: %s (run --help)\n' "$1" >&2; exit 2 ;;
  esac
done

# ---------- constants ----------

ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"

# ---------- output formatting ----------

OK="✓"
FAIL="✗"
SKIP="–"

# Sections accumulated as we go; printed at the end so the final report
# is one coherent block instead of interleaved across checks.
declare -a SECTION_PLUGINS=()
declare -a SECTION_EXTERNAL=()
declare -a SECTION_HOST=()
declare -a FIX_BLOCKS=()
declare -a FIX_AUTO_COMMANDS=()
EXIT_STATUS=0

push_plugin()   { SECTION_PLUGINS+=("    $*"); }
push_external() { SECTION_EXTERNAL+=("    $*"); }
push_host()     { SECTION_HOST+=("    $*"); }

# Two flavours of fix (M7.1.F30):
#
# - push_fix_auto <cmd>   for runnable fixes the doctor can execute itself
#                         when --fix is passed. The argument is one shell
#                         command (may contain unexpanded $ATELIER_CONFIG_DIR
#                         — `eval` at execution time expands it correctly).
#                         The command is added to BOTH the display list
#                         (FIX_BLOCKS) so the operator sees what would run
#                         AND to FIX_AUTO_COMMANDS for actual execution.
#
# - push_fix_manual <txt> for fixes the operator must apply themselves
#                         (paths to re-run install.sh, comments about
#                         settings.json hand-editing, etc.). Only added
#                         to FIX_BLOCKS for display. Never executed by
#                         --fix — these need human judgment.
#
# Both set EXIT_STATUS=1 so the doctor exits non-zero on any pending fix.
push_fix_auto() {
  FIX_BLOCKS+=("$*")
  FIX_AUTO_COMMANDS+=("$*")
  EXIT_STATUS=1
}
push_fix_manual() {
  FIX_BLOCKS+=("$*")
  EXIT_STATUS=1
}

# Strip leading "v" from a version tag if present.
strip_v() { printf '%s' "${1#v}"; }

# ---------- checks ----------
#
# CONTRACT (M7.1.F15): every check function below MUST be independent.
#   - Handle errors internally with `2>/dev/null` + conditional logic.
#   - Never rely on `set -e` (it is intentionally OFF — see top of file).
#   - Never call `exit` from inside a check; use `push_fix_auto` (for
#     runnable shell commands the doctor can execute under --fix) or
#     `push_fix_manual` (for instructions only humans should act on) to
#     set EXIT_STATUS=1 and `return` so the failure surfaces in the
#     report without aborting the rest.
#   - A failing check must produce ONE status line via `push_plugin`,
#     `push_external`, or `push_host` so the report stays complete and
#     every check the binary attempted is visible to the operator.
#
# This is what makes the report deterministic: the operator (and CI)
# sees every check, in deterministic order, regardless of which ones
# fail. New checks added below must follow the same discipline.

# fetch_upstream_version <repo> — probe a four-step chain looking for the
# latest tag of a GitHub repo (M7.1.F14). Prints the tag on stdout when
# any probe succeeds; prints nothing when all four fail.
#
# Probes in order:
#   1. `gh api repos/<r>/releases/latest`  — auth via atelier-author identity.
#   2. `gh api repos/<r>/tags`             — auth fallback for repos without releases.
#   3. unauthenticated `curl .../releases/latest` — covers PUBLIC repos when
#      the authenticated identity lacks org/scope (the F14 dogfood-3 trigger).
#   4. unauthenticated `curl .../tags`     — unauth fallback for releases-less repos.
#
# Unauth probes use the 60-req/hour anonymous GitHub API quota. Doctor runs
# emit two of these per session in the worst case (atelier + roadmap-tools);
# operators running doctor more than ~30 times per hour will see HTTP 403
# from rate-limiting — caller treats that as a generic upstream-check
# failure and surfaces it in the SKIP message.
fetch_upstream_version() {
  local repo="$1" v
  v="$(gh api "repos/$repo/releases/latest" --jq '.tag_name' 2>/dev/null)"
  [ -n "$v" ] && { printf '%s' "$v"; return; }
  v="$(gh api "repos/$repo/tags" --jq '.[0].name' 2>/dev/null)"
  [ -n "$v" ] && { printf '%s' "$v"; return; }
  v="$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null \
        | jq -r '.tag_name // empty' 2>/dev/null)"
  [ -n "$v" ] && { printf '%s' "$v"; return; }
  v="$(curl -fsSL "https://api.github.com/repos/$repo/tags" 2>/dev/null \
        | jq -r '.[0].name // empty' 2>/dev/null)"
  [ -n "$v" ] && { printf '%s' "$v"; return; }
}

check_plugin_drift() {
  local plugin_id="$1" repo="$2"
  local local_v upstream_v

  # M7.1.F29: prefix CLAUDE_CONFIG_DIR=$ATELIER_CONFIG_DIR. Without it,
  # `claude plugin list` reads the operator's personal config (~/.claude/)
  # — not the atelier-managed root (~/.claude-work/) where Phase C.2 of
  # install.sh installed the plugins. The result was a false-negative
  # "not installed" report even when the plugin was installed correctly.
  local_v="$(CLAUDE_CONFIG_DIR="$ATELIER_CONFIG_DIR" claude plugin list --json 2>/dev/null \
    | jq -r --arg id "$plugin_id" '.[] | select(.id == $id) | .version // empty')"

  if [ -z "$local_v" ]; then
    push_plugin "$FAIL $plugin_id not installed"
    push_fix_auto "CLAUDE_CONFIG_DIR=\$ATELIER_CONFIG_DIR claude plugin install $plugin_id"
    return
  fi

  upstream_v="$(fetch_upstream_version "$repo")"
  upstream_v="$(strip_v "$upstream_v")"

  if [ -z "$upstream_v" ]; then
    push_plugin "$SKIP $plugin_id $local_v (upstream check failed — tried gh auth + unauth curl; repo may be private without anon access, or GitHub rate-limited)"
    return
  fi

  if [ "$local_v" = "$upstream_v" ]; then
    push_plugin "$OK $plugin_id $local_v (up to date)"
  else
    push_plugin "$FAIL $plugin_id $local_v → $upstream_v"
    push_fix_auto "CLAUDE_CONFIG_DIR=\$ATELIER_CONFIG_DIR claude plugin marketplace update akalab-tech"
    push_fix_auto "CLAUDE_CONFIG_DIR=\$ATELIER_CONFIG_DIR claude plugin update $plugin_id"
  fi
}

check_git_wt_drift() {
  local sha_file="$HOME/.local/state/atelier/git-wt.sha"
  local recorded_sha upstream_sha

  if [ ! -f "$sha_file" ]; then
    push_external "$FAIL git-wt SHA not recorded"
    push_fix_manual "# re-run install.sh to record the git-wt SHA
/path/to/atelier/install.sh"
    return
  fi

  recorded_sha="$(<"$sha_file")"
  if [ -z "$recorded_sha" ]; then
    push_external "$FAIL git-wt SHA file empty"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi

  upstream_sha="$(gh api repos/AkaLab-Tech/git-wt/commits/main --jq '.sha' 2>/dev/null)"
  if [ -z "$upstream_sha" ]; then
    push_external "$SKIP git-wt ${recorded_sha:0:7} (upstream check failed)"
    return
  fi

  if [ "$recorded_sha" = "$upstream_sha" ]; then
    push_external "$OK git-wt ${recorded_sha:0:7} (up to date)"
  else
    push_external "$FAIL git-wt ${recorded_sha:0:7} → ${upstream_sha:0:7}"
    push_fix_manual "git clone --depth 1 https://github.com/AkaLab-Tech/git-wt.git /tmp/git-wt
/tmp/git-wt/install.sh --skill-for=claude
git -C /tmp/git-wt rev-parse HEAD > ~/.local/state/atelier/git-wt.sha
rm -rf /tmp/git-wt"
  fi
}

check_legacy_hooks() {
  local settings="$HOME/.claude/settings.json"
  if [ ! -f "$settings" ]; then
    push_host "$OK no legacy atelier hooks in ~/.claude/settings.json (file absent)"
    return
  fi
  # Look for path strings containing atelier under hooks.
  if jq -e '.hooks // {} | tostring | test("atelier|\\.claude-personal/atelier")' "$settings" >/dev/null 2>&1; then
    push_host "$FAIL legacy atelier hooks found in ~/.claude/settings.json"
    push_fix_manual "# open ~/.claude/settings.json and remove entries under \"hooks\"
# referencing atelier paths — live hooks ship via the plugin manifest now."
  else
    push_host "$OK no legacy atelier hooks in ~/.claude/settings.json"
  fi
}

check_personal_claudemd_leak() {
  # M7.1.F53 — the operator's personal ~/.claude/CLAUDE.md is loaded into
  # atelier sessions as *project* memory via Claude Code's ancestor-directory
  # walk: worktrees live under $HOME, and the walk reaches ~/.claude/CLAUDE.md.
  # This is independent of CLAUDE_CONFIG_DIR, which only relocates *user-level*
  # memory (to $ATELIER_CONFIG_DIR/CLAUDE.md). If that personal file carries
  # commit/push/merge confirmation gates, they can deny the autonomous flow's
  # push at the auto-mode classifier. Only a concern when atelier is isolated
  # to a config dir OTHER than ~/.claude (the default ~/.claude-work).
  local personal="$HOME/.claude/CLAUDE.md"
  if [ "$ATELIER_CONFIG_DIR" = "$HOME/.claude" ]; then
    push_host "$SKIP personal CLAUDE.md leak check (atelier shares ~/.claude as its config dir)"
    return
  fi
  if [ ! -f "$personal" ]; then
    push_host "$OK no personal ~/.claude/CLAUDE.md that could leak into atelier sessions"
    return
  fi
  # Flag only when a confirmation/permission concept co-occurs with a git
  # action — those are the directives that break the autonomous flow (EN+ES).
  if grep -qiE 'confirm|confirmaci|ask (before|first|me)|sin .*confirmaci|pregunt|permis|explicit' "$personal" 2>/dev/null \
     && grep -qiE 'git push|git commit|\bpush\b|\bcommit\b|\bmerge\b' "$personal" 2>/dev/null; then
    push_host "$FAIL personal ~/.claude/CLAUDE.md has commit/push confirmation rules that leak into atelier sessions"
    push_fix_manual "# Your personal ~/.claude/CLAUDE.md is loaded into EVERY atelier session as
# project memory: Claude Code walks the directories above the worktree, and
# worktrees live under \$HOME, so the walk reaches ~/.claude/CLAUDE.md.
# CLAUDE_CONFIG_DIR does NOT prevent this — it only relocates user-level memory.
# Its commit/push/merge confirmation rules can block atelier's autonomous flow.
#
# Fix: move your personal global rules out of ~/.claude/CLAUDE.md into the
# CLAUDE.md of your *personal* config root (the dir your personal Claude
# sessions use via CLAUDE_CONFIG_DIR, e.g. ~/.claude-personal/CLAUDE.md), then
# leave ~/.claude/CLAUDE.md empty or removed. Atelier's own permission matrix
# + gates stay authoritative; your personal sessions keep their rules."
  else
    push_host "$OK personal ~/.claude/CLAUDE.md present but no commit/push confirmation gates detected"
  fi
}

check_git_wt_path() {
  if command -v git-wt >/dev/null 2>&1; then
    local bin
    bin="$(command -v git-wt)"
    push_host "$OK git-wt on PATH ($bin)"
  else
    push_host "$FAIL git-wt not on PATH"
    push_fix_manual "/path/to/atelier/install.sh"
  fi
}

check_shellrc_hooks() {
  local sentinel="# >>> atelier hooks (managed by install.sh) >>>"
  local found_in=""
  if [ -f "$HOME/.zshrc" ] && grep -qF "$sentinel" "$HOME/.zshrc" 2>/dev/null; then
    found_in=".zshrc"
  elif [ -f "$HOME/.bashrc" ] && grep -qF "$sentinel" "$HOME/.bashrc" 2>/dev/null; then
    found_in=".bashrc"
  fi
  if [ -n "$found_in" ]; then
    push_host "$OK atelier shellrc hooks active (~/$found_in)"
  else
    push_host "$FAIL atelier shellrc hooks not found in ~/.zshrc or ~/.bashrc"
    push_fix_manual "/path/to/atelier/install.sh"
  fi
}

check_project_npmrc() {
  local npmrc=""
  if [ -n "${CLAUDE_PROJECT_DIR:-}" ] && [ -f "$CLAUDE_PROJECT_DIR/.npmrc" ]; then
    npmrc="$CLAUDE_PROJECT_DIR/.npmrc"
  elif [ -f "$PWD/.npmrc" ]; then
    npmrc="$PWD/.npmrc"
  fi
  if [ -z "$npmrc" ]; then
    push_host "$SKIP project .npmrc guardrails (no .npmrc in project directory)"
    return
  fi
  local missing=()
  grep -qE '^ignore-scripts[[:space:]]*=[[:space:]]*true' "$npmrc" || missing+=("ignore-scripts=true")
  grep -qE '^minimum-release-age[[:space:]]*=[[:space:]]*10080' "$npmrc" || missing+=("minimum-release-age=10080")
  grep -qE '^audit-level[[:space:]]*=[[:space:]]*moderate' "$npmrc" || missing+=("audit-level=moderate")
  if [ ${#missing[@]} -eq 0 ]; then
    push_host "$OK project .npmrc guardrails present"
  else
    push_host "$FAIL .npmrc missing: ${missing[*]}"
    push_fix_manual "# re-run /atelier:setup-project to refresh .npmrc with the three PLAN.md §4 guardrails."
  fi
}

check_coolify() {
  # Optional integration (M4.23). Silent skip when not installed.
  local config_dir="${ATELIER_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}"
  local installed=false
  if command -v claude >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if CLAUDE_CONFIG_DIR="$config_dir" claude plugin list --json 2>/dev/null \
         | jq -e '.[] | select(.id == "coolify-integration@akalab-tech")' >/dev/null; then
      installed=true
    fi
  fi
  if [ "$installed" != true ]; then
    push_host "$SKIP coolify-integration not installed (optional — run /atelier:setup-coolify to enable)"
    return
  fi
  local issues=()
  command -v atelier-coolify >/dev/null 2>&1 || issues+=("CLI not on PATH")
  local settings="$config_dir/settings.json"
  if [ -f "$settings" ] && command -v jq >/dev/null 2>&1; then
    jq -e '(.permissions.allow // []) | index("Skill(coolify-integration:*)")' "$settings" >/dev/null 2>&1 \
      || issues+=("allowlist not merged into user settings.json")
  else
    issues+=("user settings.json missing")
  fi
  if [ ${#issues[@]} -eq 0 ]; then
    push_host "$OK coolify-integration ready (per-project token/URL live in each project's .env)"
  else
    push_host "$FAIL coolify-integration: ${issues[*]}"
    push_fix_auto "atelier-setup-coolify --non-interactive"
  fi
}

check_vercel() {
  # Optional integration (M4.27). Silent skip when not installed.
  local config_dir="${ATELIER_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}"
  local installed=false
  if command -v claude >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if CLAUDE_CONFIG_DIR="$config_dir" claude plugin list --json 2>/dev/null \
         | jq -e '.[] | select(.id == "vercel-integration@akalab-tech")' >/dev/null; then
      installed=true
    fi
  fi
  if [ "$installed" != true ]; then
    push_host "$SKIP vercel-integration not installed (optional — run /atelier:setup-vercel to enable)"
    return
  fi
  local issues=()
  command -v atelier-vercel >/dev/null 2>&1 || issues+=("CLI not on PATH")
  local settings="$config_dir/settings.json"
  if [ -f "$settings" ] && command -v jq >/dev/null 2>&1; then
    jq -e '(.permissions.allow // []) | index("Skill(vercel-integration:*)")' "$settings" >/dev/null 2>&1 \
      || issues+=("allowlist not merged into user settings.json")
  else
    issues+=("user settings.json missing")
  fi
  local cli
  if command -v vercel >/dev/null 2>&1; then cli="vercel CLI installed"; else cli="vercel CLI via pnpm dlx — /atelier:setup-vercel installs it"; fi
  if [ ${#issues[@]} -eq 0 ]; then
    push_host "$OK vercel-integration ready ($cli; per-project VERCEL_TOKEN in .env)"
  else
    push_host "$FAIL vercel-integration: ${issues[*]}"
    push_fix_auto "atelier-setup-vercel --non-interactive"
  fi
}

