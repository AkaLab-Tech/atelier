}

check_workspaces() {
  # Optional (M8.x). Silent skip when no workspaces are configured.
  local ws_file="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}/workspaces.json"
  local projects_file="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}/projects.json"
  command -v jq >/dev/null 2>&1 || { push_host "$SKIP workspaces: jq not available"; return; }
  [ -f "$ws_file" ] || { push_host "$SKIP no workspaces configured (optional — /atelier:setup-workspace groups repos)"; return; }
  if ! jq empty "$ws_file" >/dev/null 2>&1; then
    push_host "$FAIL workspaces.json is not valid JSON"
    push_fix_manual "inspect ${ws_file} — it is malformed"
    return
  fi
  local slugs
  slugs="$(jq -r '.workspaces // {} | keys[]?' "$ws_file")"
  if [ -z "$slugs" ]; then
    push_host "$SKIP workspaces.json present but empty"
    return
  fi
  local slug
  while IFS= read -r slug; do
    [ -n "$slug" ] || continue
    local issues=() seen_tokens="" root token mpath
    root="$(jq -r --arg w "$slug" '.workspaces[$w].root // ""' "$ws_file")"
    [ -n "$root" ] && [ ! -d "$root" ] && issues+=("root missing ($root)")
    while IFS=$'\t' read -r token mpath; do
      [ -n "$mpath" ] || continue
      [ -d "$mpath" ] || issues+=("member '$token' path missing ($mpath)")
      if [ -f "$projects_file" ]; then
        jq -e --arg p "$mpath" '.projects[$p] // empty' "$projects_file" >/dev/null 2>&1 \
          || issues+=("member '$token' not a registered project")
      fi
      case ",$seen_tokens," in *",$token,"*) issues+=("duplicate token '$token'") ;; esac
      seen_tokens="${seen_tokens}${token},"
    done < <(jq -r --arg w "$slug" '.workspaces[$w].members[]? | "\(.token)\t\(.path)"' "$ws_file")
    if [ ${#issues[@]} -eq 0 ]; then
      local n
      n="$(jq -r --arg w "$slug" '.workspaces[$w].members | length' "$ws_file")"
      push_host "$OK workspace '$slug' — $n member(s), all registered & present"
    else
      push_host "$FAIL workspace '$slug': ${issues[*]}"
      push_fix_manual "fix workspace '$slug' — re-run /atelier:setup-workspace, or /atelier:remove-workspace ${slug} to drop the grouping"
    fi
  done <<< "$slugs"
}

check_chrome() {
  local os
  os="$(uname -s)"
  case "$os" in
    Darwin)
      if [ -d "/Applications/Google Chrome.app" ]; then
        push_host "$OK system Chrome detected"
      elif [ -d "$HOME/Applications/Google Chrome.app" ]; then
        push_host "$OK system Chrome detected (per-user install)"
      else
        push_host "$FAIL system Chrome not found"
        push_fix_manual "npx @playwright/mcp@latest install-browser chrome
# alternatively: brew install --cask google-chrome"
      fi
      ;;
    Linux)
      if command -v google-chrome >/dev/null 2>&1 || command -v google-chrome-stable >/dev/null 2>&1; then
        push_host "$OK system Chrome detected"
      else
        push_host "$FAIL system Chrome not found"
        push_fix_manual "npx @playwright/mcp@latest install-browser chrome
# alternatively (Linux): apt install google-chrome-stable"
      fi
      ;;
    *)
      push_host "$SKIP Chrome presence check not implemented for $os"
      ;;
  esac
}

check_docker_compose() {
  # Probe daemon first; skip the rest if daemon is offline.
  if ! docker info >/dev/null 2>&1; then
    push_host "$SKIP docker compose check (daemon offline)"
    return
  fi
  local v
  v="$(docker compose version --short 2>/dev/null)"
  if [ -z "$v" ]; then
    # Some older docker compose versions don't support --short.
    v="$(docker compose version 2>/dev/null | head -1 | awk '{print $NF}')"
  fi
  if [ -n "$v" ]; then
    push_host "$OK docker compose v$v detected"
  else
    push_host "$FAIL docker compose plugin not found"
    push_fix_manual "# macOS (homebrew):
brew install docker-compose
mkdir -p ~/.docker/cli-plugins
ln -sf /opt/homebrew/lib/docker/cli-plugins/docker-compose ~/.docker/cli-plugins/docker-compose

# Linux (Debian/Ubuntu):
sudo apt-get install docker-compose-plugin"
  fi
}

check_atelier_config_dir() {
  # M7.1.F11 — verify the env-var lookup chain resolves to an atelier
  # install (marker present + installStatus complete).
  if [ -z "${ATELIER_CONFIG_DIR:-}" ]; then
    push_host "$FAIL \$ATELIER_CONFIG_DIR unset (shellrc hook block missing or not sourced)"
    push_fix_manual "source ~/.zshrc   # or ~/.bashrc"
    return
  fi
  if [ ! -d "$ATELIER_CONFIG_DIR" ]; then
    push_host "$FAIL atelier config dir $ATELIER_CONFIG_DIR does not exist"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  local marker="$ATELIER_CONFIG_DIR/.atelier-managed"
  if [ ! -f "$marker" ]; then
    push_host "$FAIL marker file missing at $marker"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  local status
  status="$(jq -r '.installStatus // empty' "$marker" 2>/dev/null)"
  case "$status" in
    complete)
      push_host "$OK atelier config dir $ATELIER_CONFIG_DIR (installStatus: complete)"
      ;;
    in_progress)
      push_host "$FAIL atelier config dir $ATELIER_CONFIG_DIR (installStatus: in_progress — install crashed)"
      push_fix_manual "# install.sh Phase 0 will offer to resume (M7.1.F6)
/path/to/atelier/install.sh"
      ;;
    *)
      push_host "$FAIL atelier config dir $ATELIER_CONFIG_DIR (marker corrupt or unrecognized installStatus)"
      push_fix_manual "/path/to/atelier/install.sh"
      ;;
  esac
}

check_git_identity() {
  # M7.1.F7a + F7b + F21 — accept either public-email form OR no-reply
  # derivation from gh api user .id + .login (both are valid for the
  # same account).
  local conf="$ATELIER_CONFIG_DIR/git-identity.conf"
  if [ ! -f "$conf" ]; then
    push_host "$FAIL atelier-author git-identity.conf missing"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  local conf_name conf_email
  conf_name="$(awk -F'= ' '/^[[:space:]]*name = /{print $2}' "$conf")"
  conf_email="$(awk -F'= ' '/^[[:space:]]*email = /{print $2}' "$conf")"
  if [ -z "$conf_name" ] || [ -z "$conf_email" ]; then
    push_host "$FAIL git-identity.conf missing [user] name= or email="
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  # gh api user under the author config dir
  local gh_dir="$ATELIER_CONFIG_DIR/gh/author"
  if [ ! -d "$gh_dir" ]; then
    push_host "$FAIL atelier-author gh dir missing ($gh_dir) — cannot cross-check identity"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  local gh_login gh_id gh_email
  gh_login="$(env GH_CONFIG_DIR="$gh_dir" gh api user --jq .login 2>/dev/null)"
  gh_id="$(env GH_CONFIG_DIR="$gh_dir" gh api user --jq .id 2>/dev/null)"
  gh_email="$(env GH_CONFIG_DIR="$gh_dir" gh api user --jq -r '.email // empty' 2>/dev/null)"
  if [ -z "$gh_login" ] || [ -z "$gh_id" ]; then
    push_host "$SKIP git-identity.conf cross-check (could not read gh api user)"
    return
  fi
  # Form A: literal equality with gh api .email
  if [ -n "$gh_email" ] && [ "$conf_email" = "$gh_email" ]; then
    push_host "$OK atelier-author git identity captured: $conf_name <$conf_email>"
    return
  fi
  # Form B: no-reply derivation from .id + .login
  local noreply="${gh_id}+${gh_login}@users.noreply.github.com"
  if [ "$conf_email" = "$noreply" ]; then
    push_host "$OK atelier-author git identity captured: $conf_name <$conf_email>"
    return
  fi
  # Neither form matches → real drift
  push_host "$FAIL atelier-author git identity drift: conf has $conf_email but gh api returns $gh_email (id=$gh_id login=$gh_login)"
  push_fix_manual "# git-identity.conf doesn't match the currently-authenticated gh account.
# Re-run install.sh — Phase B will rewrite it from `gh api user`:
/path/to/atelier/install.sh"
}

check_reviewer_repo_access() {
  # M7.1.F56 — the independent reviewer agent runs under a SEPARATE GitHub
  # identity ($ATELIER_CONFIG_DIR/gh/reviewer), distinct from the author.
  # On a freshly-created PRIVATE repo that identity is not a collaborator,
  # so `gh pr review --approve` fails with "Could not resolve to a
  # Repository" and the auto-merge gate stalls silently. Verify, for the
  # CURRENT repo, that the reviewer identity can actually resolve it.
  local reviewer_dir="$ATELIER_CONFIG_DIR/gh/reviewer"
  local author_dir="$ATELIER_CONFIG_DIR/gh/author"

  if ! command -v gh >/dev/null 2>&1; then
    push_host "$SKIP reviewer repo access (gh not on PATH)"
    return
  fi
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    push_host "$SKIP reviewer repo access (not inside a git repo)"
    return
  fi
  if [ ! -d "$reviewer_dir" ]; then
    push_host "$SKIP reviewer repo access (reviewer identity not configured at $reviewer_dir)"
    return
  fi
  # Resolve owner/name via the author identity (the account that can see it).
  local owner_repo
  owner_repo="$(env GH_CONFIG_DIR="$author_dir" gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null || true)"
  if [ -z "$owner_repo" ]; then
    push_host "$SKIP reviewer repo access (no GitHub remote resolved for the current repo)"
    return
  fi
  # Can the reviewer identity resolve the repo?
  if env GH_CONFIG_DIR="$reviewer_dir" gh repo view "$owner_repo" --json nameWithOwner >/dev/null 2>&1; then
    push_host "$OK reviewer can access $owner_repo (auto-merge review path available)"
    return
  fi
  local reviewer_login
  reviewer_login="$(env GH_CONFIG_DIR="$reviewer_dir" gh api user --jq .login 2>/dev/null || true)"
  push_host "$FAIL reviewer identity${reviewer_login:+ ($reviewer_login)} cannot access $owner_repo — auto-merge review will fail"
  push_fix_manual "# Grant the reviewer GitHub user read access to $owner_repo, or the auto-merge
# review step fails with \"Could not resolve to a Repository\" and PRs stall.
# Easiest: re-run /atelier:setup-project in this repo — it offers to do this.
# Manual (as the repo admin): add the reviewer as a read collaborator, then
# have the reviewer accept the invitation:
env GH_CONFIG_DIR=\"$author_dir\" gh api -X PUT \"repos/$owner_repo/collaborators/${reviewer_login:-<reviewer-login>}\" -f permission=pull
inv=\$(env GH_CONFIG_DIR=\"$reviewer_dir\" gh api user/repository_invitations --jq '.[] | select(.repository.full_name==\"$owner_repo\") | .id' | head -1) && env GH_CONFIG_DIR=\"$reviewer_dir\" gh api -X PATCH \"user/repository_invitations/\$inv\""
}

check_atelier_auto_mode() {
  # M2.8 — verify $ATELIER_CONFIG_DIR/settings.json has
  # permissions.defaultMode == "auto" so atelier-launched sessions get
  # Claude Code's native auto-mode classifier. Empirically validated in
  # M2.7 (docs/research/permission-layer-3.md addendum) that the setting
  # is honored from $CLAUDE_CONFIG_DIR/settings.json wherever that env
  # var points; it does not require literal ~/.claude/settings.json.
  local target="$ATELIER_CONFIG_DIR/settings.json"
  if [ ! -f "$target" ]; then
    push_host "$FAIL atelier settings.json missing at $target — auto-mode not configurable"
    push_fix_manual "/path/to/atelier/install.sh"
    return
  fi
  if ! jq empty "$target" >/dev/null 2>&1; then
    push_host "$FAIL $target is not valid JSON — cannot verify auto-mode"
    push_fix_manual "# inspect and repair $target manually; then re-run install.sh"
    return
  fi
  local mode
  mode="$(jq -r '.permissions.defaultMode // ""' "$target" 2>/dev/null)"
  if [ "$mode" = "auto" ]; then
    push_host "$OK auto-mode enabled (permissions.defaultMode = \"auto\" in $target)"
    return
  fi
  if [ -z "$mode" ]; then
    push_host "$FAIL auto-mode not enabled ($target has no permissions.defaultMode)"
  else
    push_host "$FAIL auto-mode not enabled ($target has permissions.defaultMode = \"$mode\")"
  fi
  push_fix_auto "tmp=\"\$(mktemp \"$target.atelier.XXXXXX\")\" && jq '.permissions = (.permissions // {}) | .permissions.defaultMode = \"auto\"' \"$target\" > \"\$tmp\" && mv \"\$tmp\" \"$target\""
}

check_atelier_claude_auth() {
  # M7.1.F42 + F43 — verify the atelier-scoped Claude Code auth is valid
  # AGAINST THE ANTHROPIC API, not just by reading .claude.json.
  #
  # F42 used `claude auth status` which only reads the local config file
  # and checks for the presence of oauthAccount. It returns success even
  # when the OAuth access token has expired or been revoked server-side.
  # The operator hit this exact false positive: install.sh said
  # "atelier Claude Code already authenticated", atelier-doctor said
  # "✓ atelier Claude auth valid", but the next interactive session
  # failed with `API Error: 401 Invalid authentication credentials`.
  #
  # F43 (this): a real API ping via `claude -p "ok" --output-format json
  # --max-turns 1`. If the token is expired/revoked the call returns
  # exit 0 (the CLI ran) but the JSON has `api_error_status: 401`. The
  # model is never invoked when the call fails at auth, so the cost is
  # ~3s of latency and $0 in tokens. The cost is acceptable because the
  # alternative is silent false positives that surface as 401 inside
  # agent sessions the operator did not expect to fail.
  if ! command -v claude >/dev/null 2>&1; then
    push_host "$SKIP atelier Claude auth (claude CLI not on PATH)"
    return
  fi
  # Step 1 — cheap local check. If the config file itself is missing
  # there's no point doing the deep check; report and move on.
  if ! CLAUDE_CONFIG_DIR="$ATELIER_CONFIG_DIR" claude auth status >/dev/null 2>&1; then
    push_host "$FAIL atelier Claude auth missing in $ATELIER_CONFIG_DIR/.claude.json"
    push_fix_manual "CLAUDE_CONFIG_DIR=\"$ATELIER_CONFIG_DIR\" claude auth login"
    return
  fi
  # Step 2 — deep check via minimal API ping. Catches expired or
  # revoked tokens that the local file still claims are valid.
  local response api_status email
  response="$(CLAUDE_CONFIG_DIR="$ATELIER_CONFIG_DIR" claude -p "ok" --output-format json --max-turns 1 2>/dev/null || true)"
  api_status="$(printf '%s' "$response" | jq -r '.api_error_status // empty' 2>/dev/null)"
  if [ -n "$api_status" ]; then
    push_host "$FAIL atelier Claude auth invalid (Anthropic API returned $api_status — token expired or revoked)"
    push_fix_manual "CLAUDE_CONFIG_DIR=\"$ATELIER_CONFIG_DIR\" claude auth logout
CLAUDE_CONFIG_DIR=\"$ATELIER_CONFIG_DIR\" claude auth login"
    return
  fi
  # All good — emit the OK with the account email for context.
  email="$(CLAUDE_CONFIG_DIR="$ATELIER_CONFIG_DIR" claude auth status --json 2>/dev/null | jq -r '.email // empty')"
  if [ -z "$email" ]; then
    email="$(CLAUDE_CONFIG_DIR="$ATELIER_CONFIG_DIR" claude auth status 2>&1 | grep -Eio '[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}' | head -1 || true)"
  fi
  if [ -n "$email" ]; then
    push_host "$OK atelier Claude auth valid (account: $email, API ping OK)"
  else
    push_host "$OK atelier Claude auth valid (API ping OK)"
  fi
}

# ---------- main ----------
#
# Args were parsed at the top of the script into $RUN_FIXES; --help also
# branched out there. No further arg handling is needed here.

# Run checks in deterministic order.
check_plugin_drift "atelier@akalab-tech"               "AkaLab-Tech/atelier"
check_plugin_drift "claude-roadmap-tools@akalab-tech"  "AkaLab-Tech/claude-roadmap-tools"
check_git_wt_drift
check_legacy_hooks
check_personal_claudemd_leak
check_git_wt_path
check_shellrc_hooks
check_project_npmrc
check_chrome
check_docker_compose
check_coolify
check_vercel
check_neon
check_workspaces
check_atelier_config_dir
check_atelier_claude_auth
check_git_identity
check_reviewer_repo_access
check_atelier_auto_mode

# ---------- emit the report ----------

printf 'atelier /doctor — health check\n\n'

printf 'Plugins (compared against AkaLab-Tech/claude-plugins marketplace)\n'
for line in "${SECTION_PLUGINS[@]}"; do printf '%s\n' "$line"; done
printf '\n'

printf 'External tooling\n'
for line in "${SECTION_EXTERNAL[@]}"; do printf '%s\n' "$line"; done
printf '\n'

printf 'Host checks\n'
for line in "${SECTION_HOST[@]}"; do printf '%s\n' "$line"; done
printf '\n'

if [ ${#FIX_BLOCKS[@]} -eq 0 ]; then
  printf 'All checks passed. atelier is up to date.\n'
  exit 0
fi

# There ARE pending fixes. Two paths from here:
#   --fix mode: print + execute the runnable ones, then summarise.
#   default:    print all the suggestions + the --fix hint when any auto
#               fix is runnable, then exit 1.

if ! $RUN_FIXES; then
  printf 'To apply pending fixes, run:\n\n'
  for block in "${FIX_BLOCKS[@]}"; do
    printf '%s\n\n' "$block"
  done
  if [ ${#FIX_AUTO_COMMANDS[@]} -gt 0 ]; then
    # shellcheck disable=SC2016
    printf 'Tip: run `atelier-doctor --fix` to auto-execute the %d runnable fix(es).\n' \
      "${#FIX_AUTO_COMMANDS[@]}"
    if [ ${#FIX_AUTO_COMMANDS[@]} -lt ${#FIX_BLOCKS[@]} ]; then
      printf '     The remaining %d manual fix(es) above still need your attention.\n' \
        $(( ${#FIX_BLOCKS[@]} - ${#FIX_AUTO_COMMANDS[@]} ))
    fi
  fi
  exit "$EXIT_STATUS"
fi

# --fix mode: execute the auto commands; print manual blocks for the
# operator to handle separately.
APPLIED_OK=0
APPLIED_FAIL=0

if [ ${#FIX_AUTO_COMMANDS[@]} -gt 0 ]; then
  printf 'Applying %d runnable fix(es)\n\n' "${#FIX_AUTO_COMMANDS[@]}"
  for cmd in "${FIX_AUTO_COMMANDS[@]}"; do
    printf '  $ %s\n' "$cmd"
    # `eval` is the only way to expand $ATELIER_CONFIG_DIR (and any other
    # var the runnable used a literal $... for). The command originates
    # from this script's own check functions — not from user input — so
    # the eval surface is bounded by what we ourselves call push_fix_auto
    # with. We capture and suppress the command's normal output, then
    # surface a one-line OK / FAIL summary.
    if output="$(eval "$cmd" 2>&1)"; then
      printf '    %s OK\n' "$OK"
      APPLIED_OK=$(( APPLIED_OK + 1 ))
    else
      rc=$?
      printf '    %s FAIL (rc=%d)\n' "$FAIL" "$rc"
      printf '%s\n' "$output" | sed 's/^/      /'
      APPLIED_FAIL=$(( APPLIED_FAIL + 1 ))
    fi
    printf '\n'
  done
fi

# Surface any manual fix blocks that --fix can't act on.
manual_count=$(( ${#FIX_BLOCKS[@]} - ${#FIX_AUTO_COMMANDS[@]} ))
if [ "$manual_count" -gt 0 ]; then
  printf 'The following %d fix(es) need manual action:\n\n' "$manual_count"
  # FIX_BLOCKS contains both auto and manual entries interleaved by check
  # order. To get just the manuals, we'd need a parallel array — but for
  # the operator's purposes, replaying every block (with the runnable
  # ones marked as already-applied above) is simpler and equally
  # informative. Print every block; the operator skips the ones the
  # `Applying` section already covered.
  for block in "${FIX_BLOCKS[@]}"; do
    printf '%s\n\n' "$block"
  done
fi

if [ "$APPLIED_FAIL" -gt 0 ]; then
  printf 'Summary: %d fix(es) applied OK, %d failed, %d need manual action.\n' \
    "$APPLIED_OK" "$APPLIED_FAIL" "$manual_count"
  exit 1
elif [ "$manual_count" -gt 0 ]; then
  printf 'Summary: %d fix(es) applied OK, %d need manual action.\n' \
    "$APPLIED_OK" "$manual_count"
  exit 1
else
  # shellcheck disable=SC2016
  printf 'Summary: %d fix(es) applied OK. Re-run `atelier-doctor` to verify.\n' "$APPLIED_OK"
  exit 0
fi
