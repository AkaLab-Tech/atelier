  if [ "$installed" != true ]; then
    push_host "$SKIP neon-integration not installed (optional — run /atelier:setup-neon to enable)"
    return
  fi
  local issues=()
  command -v atelier-neon >/dev/null 2>&1 || issues+=("CLI not on PATH")
  local settings="$config_dir/settings.json"
  if [ -f "$settings" ] && command -v jq >/dev/null 2>&1; then
    jq -e '(.permissions.allow // []) | index("Skill(neon-integration:*)")' "$settings" >/dev/null 2>&1 \
      || issues+=("allowlist not merged into user settings.json")
  else
    issues+=("user settings.json missing")
  fi
  local cli
