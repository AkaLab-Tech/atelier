#!/usr/bin/env bash
#
# atelier-workspace-status — aggregated, read-only status for one workspace:
# one row per member (on-disk status · in-progress task · open-task count ·
# cross-repo-blocked count) plus a "cross-repo blocked" section listing every
# member task whose `blocked_by:<token>#id` is not yet satisfied. See PLAN.md
# §15.6. Does not overload `/status` (which is single-project by contract).
#
# The workspace is resolved from the positional <slug>, else from --from
# <path> / cwd: if that path is a workspace root or a registered member, its
# workspace is used.
#
# Usage:
#   atelier-workspace-status [<slug>] [--from <path>] [--json]
#   atelier-workspace-status --help
#
# Exit codes:
#   0  rendered successfully
#   1  unrecoverable error (no workspaces.json, jq missing, malformed JSON)
#   2  could not resolve a workspace (bad slug, or path not in any workspace)

set -euo pipefail
IFS=$'\n\t'

VERSION="0.1.0"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

die()    { printf '!!  ERROR: %s\n' "$*" >&2; exit 1; }
resolve_fail() { printf '!!  %s\n' "$*" >&2; exit 2; }

usage() {
  cat <<EOF
${SCRIPT_NAME} ${VERSION}

Aggregated read-only status for one atelier workspace. See PLAN.md §15.6.

USAGE:
  ${SCRIPT_NAME} [<slug>] [--from <path>] [--json]
  ${SCRIPT_NAME} --help

OPTIONS:
  <slug>        Workspace id. If omitted, resolved from --from / cwd (a
                workspace root or a registered member of one).
  --from <path> Path to resolve the workspace from (default: cwd).
  --json        Emit machine-readable JSON instead of the dashboard.
  --help, -h    Show this help and exit.

EXIT CODES:
  0  rendered · 1  unrecoverable error · 2  could not resolve a workspace
EOF
}

# ---------- arg parse ----------
SLUG=""
FROM_PATH=""
MODE="default"
while [ $# -gt 0 ]; do
  case "$1" in
    --from)    FROM_PATH="${2:-}"; shift 2 ;;
    --from=*)  FROM_PATH="${1#--from=}"; shift ;;
    --json)    MODE="json"; shift ;;
    --help|-h) usage; exit 0 ;;
    --)        shift; break ;;
    -*)        die "unknown flag: $1 (run --help for usage)" ;;
    *)         [ -n "$SLUG" ] && die "unexpected arg: $1"; SLUG="$1"; shift ;;
  esac
done

# ---------- config + deps ----------
ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
WORKSPACES_FILE="$ATELIER_CONFIG_DIR/workspaces.json"

command -v jq >/dev/null 2>&1 || die "jq not found in PATH"
[ -f "$WORKSPACES_FILE" ] || die "$WORKSPACES_FILE not found — no workspaces configured (run /atelier:setup-workspace)"
jq empty "$WORKSPACES_FILE" >/dev/null 2>&1 || die "$WORKSPACES_FILE is not valid JSON"

canonicalise() {
  local input="$1"
  case "$input" in /*) ;; *) input="$(pwd)/$input" ;; esac
  if [ -d "$input" ]; then (cd -P "$input" && pwd); else printf '%s\n' "$input"; fi
}

# ---------- resolve the workspace ----------
if [ -z "$SLUG" ]; then
  probe="$(canonicalise "${FROM_PATH:-$(pwd)}")"
  # First try an exact workspace-root match, then member membership.
  SLUG="$(jq -r --arg p "$probe" '
    .workspaces // {} | to_entries[]
    | select(.value.root == $p or any(.value.members[]?; .path == $p))
    | .key
  ' "$WORKSPACES_FILE" 2>/dev/null | head -n1)"
  [ -n "$SLUG" ] || resolve_fail "no workspace at '$probe' — pass a <slug> or run from a workspace root/member. Known: $(jq -r '.workspaces // {} | keys | join(", ")' "$WORKSPACES_FILE")"
fi

jq -e --arg w "$SLUG" '.workspaces[$w] // empty' "$WORKSPACES_FILE" >/dev/null 2>&1 \
  || resolve_fail "workspace '$SLUG' not found. Known: $(jq -r '.workspaces // {} | keys | join(", ")' "$WORKSPACES_FILE")"

ROOT="$(jq -r --arg w "$SLUG" '.workspaces[$w].root // ""' "$WORKSPACES_FILE")"

# ---------- per-member computations ----------
# On-disk status (mirrors atelier-list-projects compute_status).
compute_status() {
  local path="$1"
  [ -d "$path" ] || { printf 'missing-directory'; return; }
  if [ -f "$path/.claude/settings.json" ] && [ -f "$path/.atelier.json" ]; then
    printf 'configured'
  elif [ -f "$path/.claude/settings.json" ] || [ -f "$path/.atelier.json" ]; then
    printf 'partial'
  else
    printf 'missing-files'
  fi
}

# Count unchecked `- [ ]` items in a ROADMAP.md (0 if absent).
open_count() {
  [ -f "$1/ROADMAP.md" ] || { printf '0'; return; }
  # M7.1.F72: `grep -c` already prints the count (0 included) but exits 1 when it
  # is zero. The old `|| printf '0'` then printed a SECOND 0, yielding "0\n0" —
  # the embedded newline is what wrapped/garbled the status row. `|| true` keeps
  # the single printed count and just absorbs the exit code (matches the xb rows).
  grep -cE '^[[:space:]]*- \[ \]' "$1/ROADMAP.md" 2>/dev/null || true
}

# PLAN.md §5 conformance of a member's ROADMAP.md — mirrors detect_roadmap_format
# in atelier-setup-project (M7.1.F74). `conforming` = has a P0/P1/P2 priority
# heading (task-discovery / next-task can claim its tasks); `non-conforming` =
# ROADMAP exists but has none (foreign / High-Med-Low layout); `absent` = no file.
roadmap_format() {
  [ -f "$1/ROADMAP.md" ] || { printf 'absent'; return; }
  if grep -Eq '^#{1,6}[^A-Za-z0-9]*P[012]([^A-Za-z0-9]|$)' "$1/ROADMAP.md"; then
    printf 'conforming'
  else
    printf 'non-conforming'
  fi
}

PROJECTS_FILE="$ATELIER_CONFIG_DIR/projects.json"

# Installed atelier version (best-effort) for per-member setup-drift hints —
# resolved from the plugin root this script lives in (via the symlink chain).
installed_version() {
  local self="${BASH_SOURCE[0]}" d cand
  while [ -L "$self" ]; do
    d="$(cd -P "$(dirname "$self")" && pwd)"; self="$(readlink "$self")"
    case "$self" in /*) ;; *) self="$d/$self" ;; esac
  done
  d="$(cd -P "$(dirname "$self")" && pwd)"
  for cand in "${ATELIER_PLUGIN_ROOT:-}" "$(dirname "$d")"; do
    [ -n "$cand" ] || continue
    if [ -f "$cand/.claude-plugin/plugin.json" ]; then
      jq -r '.version // empty' "$cand/.claude-plugin/plugin.json" 2>/dev/null; return
    fi
  done
}

# setup_version_of PATH → the setupVersion recorded in projects.json, or ''.
setup_version_of() {
  [ -f "$PROJECTS_FILE" ] || return 0
  jq -r --arg p "$1" '.projects[$p].setupVersion // empty' "$PROJECTS_FILE" 2>/dev/null
}

# older_than A B → true if semver A is strictly older than B (pure bash, no
# `sort -V` so it stays portable to BSD/macOS).
older_than() {
  [ -n "$1" ] && [ -n "$2" ] && [ "$1" != "$2" ] || return 1
  local IFS='.' a b i x y
  a=($1); b=($2)
  for i in 0 1 2; do
    x="${a[$i]:-0}"; y="${b[$i]:-0}"; x="${x%%[!0-9]*}"; y="${y%%[!0-9]*}"
    [ "${x:-0}" -lt "${y:-0}" ] && return 0
    [ "${x:-0}" -gt "${y:-0}" ] && return 1
  done
  return 1
}
CURRENT_VERSION="$(installed_version || true)"

# First active task in IN_PROGRESS.md (a `- [ ]`/`- [x]` line that is not an
# HTML comment), trimmed; "—" when none.
in_progress_task() {
  local f="$1/IN_PROGRESS.md" line
  [ -f "$f" ] || { printf '—'; return; }
  line="$(grep -nE '^[[:space:]]*- \[[ xX]\]' "$f" 2>/dev/null | grep -v '<!--' | head -n1 | sed 's/^[0-9]*://')"
  if [ -z "$line" ]; then printf '—'; return; fi
  # Trim leading "- [ ] " and surrounding whitespace.
  line="$(printf '%s' "$line" | sed -E 's/^[[:space:]]*- \[[ xX]\][[:space:]]*//')"
  # M7.1.F72: emit the full title untruncated. It is printed on its own indented
  # line by the caller, so it never shifts the fixed-width status columns and a
  # byte-truncation can't split a multibyte (accented) character.
  printf '%s' "$line"
}

# Emit cross-repo blockers for a member that are NOT satisfied, one per line:
#   "<member-token>\t<task-id>\t<title>\t<blocker-token>#<id>\t<verdict>"
# Parses unchecked ROADMAP lines carrying a `blocked_by:` with a token#id.
member_xrepo_blocked() {
  local mpath="$1" mtoken="$2" line bb task_id title blk btok bid verdict rc
  [ -f "$mpath/ROADMAP.md" ] || return 0
  while IFS= read -r line; do
    case "$line" in *blocked_by:*) ;; *) continue ;; esac
    bb="$(printf '%s' "$line" | sed -nE 's/.*blocked_by:([^ `]*).*/\1/p')"
    [ -n "$bb" ] || continue
    task_id="$(printf '%s' "$line" | grep -oE '#[A-Za-z0-9._-]+' | head -n1)"
    title="$(printf '%s' "$line" | sed -E 's/^[[:space:]]*- \[ \][[:space:]]*//; s/`[^`]*`//g; s/blocked_by:[^ ]*//; s/#[A-Za-z0-9._-]+//g; s/~[0-9A-Za-z]+//g; s/[[:space:]]+/ /g; s/^ //; s/ $//')"
    IFS=',' read -r -a blks <<< "$bb"
    for blk in "${blks[@]}"; do
      case "$blk" in
        *#*) ;; *) continue ;;
      esac
      btok="${blk%%#*}"; bid="${blk#*#}"
      [ -n "$btok" ] || continue          # intra-repo (#id) — handled in-file, skip here
      set +e
      verdict="$(atelier-resolve-dep --from "$mpath" --token "$btok" --id "#$bid" 2>/dev/null)"; rc=$?
      set -e
      [ "$rc" -eq 0 ] && continue          # satisfied — not blocked
      printf '%s\t%s\t%s\t%s#%s\t%s\n' "$mtoken" "${task_id:-?}" "${title:-?}" "$btok" "$bid" "${verdict:-error}"
    done
  done < <(grep -E '^[[:space:]]*- \[ \].*blocked_by:' "$mpath/ROADMAP.md" 2>/dev/null)
}

# ---------- gather members ----------
declare -a M_TOKENS=() M_PATHS=()
while IFS=$'\t' read -r tok path; do
  [ -n "$path" ] || continue
  M_TOKENS+=("$tok"); M_PATHS+=("$path")
done < <(jq -r --arg w "$SLUG" '.workspaces[$w].members[]? | "\(.token)\t\(.path)"' "$WORKSPACES_FILE")

# Collect cross-repo-blocked rows once (used by both render modes).
XREPO_ROWS=""
for i in "${!M_PATHS[@]}"; do
  rows="$(member_xrepo_blocked "${M_PATHS[$i]}" "${M_TOKENS[$i]}")"
  [ -n "$rows" ] && XREPO_ROWS+="$rows"$'\n'
done

# ---------- render ----------
if [ "$MODE" = "json" ]; then
  members_json="$(
    for i in "${!M_PATHS[@]}"; do
      p="${M_PATHS[$i]}"; t="${M_TOKENS[$i]}"
      st="$(compute_status "$p")"; oc="$(open_count "$p")"
      xb="$(printf '%s' "$XREPO_ROWS" | { grep -cE "^${t}	" || true; })"
      ip="$(in_progress_task "$p")"; rf="$(roadmap_format "$p")"
      jq -n --arg token "$t" --arg path "$p" --arg status "$st" \
            --arg inprogress "$ip" --arg roadmapfmt "$rf" \
            --argjson open "${oc:-0}" --argjson xblocked "${xb:-0}" \
            '{token:$token, path:$path, status:$status, inProgress:$inprogress, roadmapFormat:$roadmapfmt, openTasks:$open, crossRepoBlocked:$xblocked}'
    done | jq -s '.'
  )"
  blocked_json="$(printf '%s' "$XREPO_ROWS" | jq -R 'select(length>0) | split("\t") | {member:.[0], task:.[1], title:.[2], blocker:.[3], verdict:.[4]}' | jq -s '.')"
  jq -n --arg ws "$SLUG" --arg root "$ROOT" --argjson members "$members_json" --argjson blocked "$blocked_json" \
    '{workspace:$ws, root:$root, members:$members, crossRepoBlocked:$blocked}'
  exit 0
fi

# Default human dashboard.
# Colours gated on a TTY + absence of NO_COLOR (repo convention). This branch is
# only reached in default mode (--json / --quiet exit earlier), so the gate is
# purely about the terminal.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_CYAN=$'\033[36m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''; C_GREEN=''; C_YELLOW=''; C_RED=''; C_CYAN=''
fi

printf '%sWorkspace: %s%s' "$C_BOLD" "$SLUG" "$C_RESET"
[ -n "$ROOT" ] && printf '   %s·   root: %s   ·   %d member(s)%s' "$C_DIM" "$ROOT" "${#M_PATHS[@]}" "$C_RESET"
printf '\n\n'

if [ "${#M_PATHS[@]}" -eq 0 ]; then
  printf '  (no members)\n'
  exit 0
fi

# Footer accumulators (space-separated member tokens; counted with wc -w).
S_NONSEC5=''; S_INPROG=''; S_DRIFT=''; S_PARTIAL=''

printf '%sMembers%s\n' "$C_BOLD" "$C_RESET"
for i in "${!M_PATHS[@]}"; do
  p="${M_PATHS[$i]}"; t="${M_TOKENS[$i]}"
  st="$(compute_status "$p")"; oc="$(open_count "$p")"; ip="$(in_progress_task "$p")"
  xb="$(printf '%s' "$XREPO_ROWS" | { grep -cE "^${t}	" || true; })"
  rf="$(roadmap_format "$p")"
  case "$st" in
    configured)            gcol="$C_GREEN";  glyph='✓' ;;
    partial|missing-files) gcol="$C_YELLOW"; glyph='⚠' ;;
    missing-directory)     gcol="$C_RED";    glyph='✗' ;;
    *)                     gcol='';          glyph='?' ;;
  esac

  # Line 1: fixed-width glyph + token + counts (never wraps — F72).
  printf '  %s%s%s %s%-22s%s  open %-3s  x-repo-blocked %s\n' \
    "$gcol" "$glyph" "$C_RESET" "$C_BOLD" "$t" "$C_RESET" "${oc:-0}" "${xb:-0}"

  # in-progress (untruncated, own line) + a resume hint when occupied.
  if [ "$ip" = "—" ]; then
    printf '      %sin-progress: —%s\n' "$C_DIM" "$C_RESET"
  else
    printf '      in-progress: %s   %s→ /atelier:resume-task%s\n' "$ip" "$C_DIM" "$C_RESET"
    S_INPROG="$S_INPROG $t"
  fi

  # roadmap §5 conformance + adoption hint.
  case "$rf" in
    non-conforming)
      printf '      %sroadmap §5: no%s   %s→ /atelier:onboard-workspace %s%s\n' "$C_YELLOW" "$C_RESET" "$C_DIM" "$SLUG" "$C_RESET"
      S_NONSEC5="$S_NONSEC5 $t" ;;
    absent)
      printf '      %sroadmap §5: no ROADMAP.md%s\n' "$C_YELLOW" "$C_RESET" ;;
  esac

  # version drift vs installed.
  sv="$(setup_version_of "$p")"
  if older_than "$sv" "$CURRENT_VERSION"; then
    printf '      %s↻ set up with v%s, installed is v%s — /atelier:setup-project to resync%s\n' "$C_YELLOW" "$sv" "$CURRENT_VERSION" "$C_RESET"
    S_DRIFT="$S_DRIFT $t"
  fi

  # partial / missing config fixes.
  case "$st" in
    partial|missing-files)
      printf '      %s→ re-run /atelier:setup-project to restore atelier files%s\n' "$C_DIM" "$C_RESET"
      S_PARTIAL="$S_PARTIAL $t" ;;
    missing-directory)
      printf "      %s→ atelier-remove-project '%s' to unregister%s\n" "$C_DIM" "$p" "$C_RESET" ;;
  esac
done

# Cross-repo blocked.
blocked_n="$(printf '%s' "$XREPO_ROWS" | grep -cE '.' || true)"
printf '\n%sCross-repo blocked (%s)%s\n' "$C_BOLD" "${blocked_n:-0}" "$C_RESET"
if [ "${blocked_n:-0}" -eq 0 ]; then
  printf '  %s(none — every cross-repo blocked_by is satisfied)%s\n' "$C_DIM" "$C_RESET"
else
  while IFS=$'\t' read -r mtok task title blk verdict; do
    [ -n "$mtok" ] || continue
    printf '  %s%s %s  %s  %s— blocked_by %s (%s)%s\n' "$C_YELLOW" "$mtok" "$task" "$title" "$C_RESET" "$blk" "$verdict" "$C_RESET"
  done < <(printf '%s' "$XREPO_ROWS")
fi

# ---------- suggested next steps ----------
list() { printf '%s' "${1# }" | sed 's/ /, /g'; }   # " a b" -> "a, b"
cnt()  { printf '%s' "$1" | wc -w | tr -d ' '; }

printf '\n%sSuggested next steps%s\n' "$C_BOLD" "$C_RESET"
if [ -n "$S_PARTIAL" ]; then
  printf '  %s•%s %s partially configured (%s) %s→ /atelier:setup-project%s\n' "$C_CYAN" "$C_RESET" "$(cnt "$S_PARTIAL")" "$(list "$S_PARTIAL")" "$C_DIM" "$C_RESET"
fi
if [ -n "$S_NONSEC5" ]; then
  printf '  %s•%s %s member(s) not §5 (%s) %s→ /atelier:onboard-workspace %s%s\n' "$C_CYAN" "$C_RESET" "$(cnt "$S_NONSEC5")" "$(list "$S_NONSEC5")" "$C_DIM" "$SLUG" "$C_RESET"
fi
if [ -n "$S_DRIFT" ]; then
  printf '  %s•%s %s on an older setup (%s) %s→ /atelier:setup-project to resync%s\n' "$C_CYAN" "$C_RESET" "$(cnt "$S_DRIFT")" "$(list "$S_DRIFT")" "$C_DIM" "$C_RESET"
fi
if [ "${blocked_n:-0}" -gt 0 ]; then
  printf '  %s•%s %s cross-repo blocker(s) unsatisfied %s→ merge the blocking member first%s\n' "$C_CYAN" "$C_RESET" "${blocked_n}" "$C_DIM" "$C_RESET"
fi
if [ -n "$S_INPROG" ]; then
  printf '  %s•%s %s with work in progress (%s) %s→ /atelier:resume-task in that member%s\n' "$C_CYAN" "$C_RESET" "$(cnt "$S_INPROG")" "$(list "$S_INPROG")" "$C_DIM" "$C_RESET"
fi
printf '  %s•%s claim / continue work %s→ task   (from this root; member picker)%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$C_RESET"
printf '  %s•%s full health %s→ atelier-doctor%s\n' "$C_CYAN" "$C_RESET" "$C_DIM" "$C_RESET"
