#!/usr/bin/env bash
#
# atelier-update — update an atelier install to the latest release.
#
# Two delivery modes (#39):
#   clone   : legacy/dev flow — git fetch + merge --ff-only on the clone,
#             then refresh the versioned runtime dir, instantiated templates,
#             plugin cache, and helper symlinks.
#   managed : repo-less flow (#39 F4) — `claude plugin update` refreshes
#             Claude Code's plugin cache, the new version is copied into the
#             versioned runtime dir ($ATELIER_RUNTIME_DIR, default
#             ~/.local/share/atelier) and `current` is atomically swapped.
#             No git operations anywhere. The runtime-dir copy/swap/prune is
#             install.sh's F2 implementation, sourced in a subshell from the
#             install.sh the plugin cache ships.
#
# In BOTH modes the ~/.local/bin helper symlinks converge on
# $RUNTIME_BASE/current/scripts/ — never on the clone or the plugin cache.
#
# Permission-diff prompting for settings.template.json changes is M6.1.b and
# only runs on the clone-mode pulled path (it needs git history for the old
# template); managed mode backs up the previous instantiated template instead.
#
# Usage:
#   atelier-update [--dry-run] [--plugin-root <path>]
#   atelier-update --help
#
# Exit codes:
#   0  update applied (something changed / drift resynced)
#   1  unrecoverable error (git pull failed, jq missing, no plugin cache, ...)
#   2  already up to date (nothing to do)

set -euo pipefail
IFS=$'\n\t'

VERSION="0.1.0"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

# ---------- logging (mirrors install.sh + other atelier helpers) ----------
log()    { printf '==> %s\n' "$*"; }
sublog() { printf '    %s\n' "$*"; }
warn()   { printf '!!  %s\n' "$*" >&2; }
die()    { printf '!!  ERROR: %s\n' "$*" >&2; exit 1; }
ok()     { printf '    OK: %s\n' "$*"; }

# ---------- plugin cache helpers ----------
# Version of the atelier plugin currently in Claude Code's plugin cache
# (what sessions actually load), read from the atelier-managed config root.
# Echoes the version string, or nothing if it cannot be determined.
read_cached_plugin_version() {
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  local manifest="$cfg/plugins/installed_plugins.json"
  [ -f "$manifest" ] || return 0
  jq -r '.plugins["atelier@akalab-tech"][0].version // empty' "$manifest" 2>/dev/null || true
}

# Trigger `claude plugin update` for both atelier plugins so Claude Code's
# plugin cache lands on the clone's version. Open sessions keep loading the
# old version until they restart — callers surface that in their report.
#
# M7.1.F29: prefix CLAUDE_CONFIG_DIR=$ATELIER_CONFIG_DIR so the update hits
# the atelier-managed root (~/.claude-work/) where install.sh Phase C.2
# installed the plugins, not the operator's personal ~/.claude/. Without it,
# `claude plugin update` no-ops against the default config (no plugin to
# update) and the atelier cache stays stale.
refresh_plugin_cache() {
  command -v claude >/dev/null 2>&1 || return 0
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  log "refreshing Claude Code plugin cache"
  # </dev/null: claude plugin update prompts interactively; without it the cache refresh hangs — mirrors atelier-uninstall L209
  if CLAUDE_CONFIG_DIR="$cfg" claude plugin update atelier@akalab-tech </dev/null 2>/dev/null; then
    sublog "claude plugin update atelier@akalab-tech: OK"
  else
    warn "claude plugin update atelier@akalab-tech failed (continuing)"
  fi
  if CLAUDE_CONFIG_DIR="$cfg" claude plugin update claude-roadmap-tools@akalab-tech </dev/null 2>/dev/null; then
    sublog "claude plugin update claude-roadmap-tools@akalab-tech: OK"
  else
    warn "claude plugin update claude-roadmap-tools@akalab-tech failed (continuing)"
  fi
}

# ---------- template + symlink resync helpers (M7.1.F61 / F60) ----------
# UTC timestamp for backup filenames (mirrors atelier-setup-project).
utc_ts() { date -u +%Y-%m-%dT%H-%M-%SZ; }

# True (0) when any instantiated template under $ATELIER_CONFIG_DIR/templates/
# differs from the clone source (after the <atelier-config-dir> substitution).
# The instantiated copy is what setup-project reads, so a stale template means
# freshly-(re)configured projects silently miss permission/config changes
# shipped in a release — independent of whether the plugin cache is current.
# This is the dimension M7.1.F58 missed: it only compared the cache version.
templates_out_of_sync() {
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  [ -d "$cfg/templates" ] || return 1
  local src dst tmp
  src="$PLUGIN_ROOT/templates/settings.template.json"
  dst="$cfg/templates/settings.template.json"
  if [ -f "$src" ]; then
    tmp="$(mktemp)"
    sed "s|<atelier-config-dir>|$cfg|g" "$src" > "$tmp"
    if ! diff -q "$dst" "$tmp" >/dev/null 2>&1; then rm -f "$tmp"; return 0; fi
    rm -f "$tmp"
  fi
  local t
  for t in project-claude.md.template atelier.template.json; do
    [ -f "$PLUGIN_ROOT/templates/$t" ] || continue
    diff -q "$cfg/templates/$t" "$PLUGIN_ROOT/templates/$t" >/dev/null 2>&1 || return 0
  done
  return 1
}

# Refresh the instantiated templates from the clone, backing up
# settings.template.json whenever its content changes (the permission set may
# differ). Headless and idempotent — used by the cache-drift path, which has
# no pulled-commit delta to drive the normal refresh block below.
refresh_instantiated_templates() {
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  [ -d "$cfg/templates" ] || { warn "$cfg/templates missing — run install.sh"; return 0; }
  log "refreshing instantiated templates in $cfg/templates/"
  local src dst tmp
  src="$PLUGIN_ROOT/templates/settings.template.json"
  dst="$cfg/templates/settings.template.json"
  if [ -f "$src" ]; then
    tmp="$(mktemp)"
    sed "s|<atelier-config-dir>|$cfg|g" "$src" > "$tmp"
    if [ -f "$dst" ] && diff -q "$dst" "$tmp" >/dev/null 2>&1; then
      rm -f "$tmp"
    else
      [ -f "$dst" ] && { cp "$dst" "$dst.bak.$(utc_ts)"; sublog "backed up settings.template.json (permission set may have changed)"; }
      mv "$tmp" "$dst"
      sublog "refreshed settings.template.json"
    fi
  fi
  local t
  for t in project-claude.md.template atelier.template.json; do
    [ -f "$PLUGIN_ROOT/templates/$t" ] || continue
    cp "$PLUGIN_ROOT/templates/$t" "$cfg/templates/$t"
    sublog "refreshed $t"
  done
}

# The scripts/ dir the ~/.local/bin helper symlinks must resolve through —
# the managed runtime `current` symlink (#39 F2/F4), in BOTH clone and
# managed mode, so a version bump swaps every helper atomically. Falls back
# to the source tree's scripts/ only for pre-F2 installs whose runtime dir
# was never materialized (they converge the next time a runtime swap runs).
runtime_scripts_dir() {
  if [ -d "$RUNTIME_BASE/current/scripts" ]; then
    printf '%s/current/scripts\n' "$RUNTIME_BASE"
  else
    printf '%s/scripts\n' "$PLUGIN_ROOT"
  fi
}

# True (0) when any atelier-* helper is missing from ~/.local/bin or points
# somewhere other than the runtime `current` dir (#39 F4 — was: the clone). A
# release that adds a helper (e.g. M5.4's atelier-housekeeping) leaves it
# unlinked until install.sh is re-run by hand — atelier-update never
# re-symlinked. This closes that gap (F60).
symlinks_out_of_sync() {
  local bin_dir="$HOME/.local/bin"
  local scripts_dir src name dest
  scripts_dir="$(runtime_scripts_dir)"
  for src in "$scripts_dir"/atelier-*; do
    [ -f "$src" ] || continue
    name="$(basename "$src")"
    dest="$bin_dir/$name"
    if [ -L "$dest" ]; then
      [ "$(readlink "$dest")" = "$src" ] || return 0
    elif [ ! -e "$dest" ]; then
      return 0
    fi
  done
  return 1
}

# Symlink every atelier-* helper into ~/.local/bin (idempotent; mirrors
# install.sh's _phase_c_1_symlink_helper but auto-discovers, so a newly shipped
# helper never needs a matching install.sh edit to be linked). Never clobbers a
# plain file the operator may have pinned manually. #39 F4: link targets route
# through $RUNTIME_BASE/current/scripts/ in both modes (clone-era links that
# still point at the clone are migrated by the "points elsewhere" branch).
resync_script_symlinks() {
  local bin_dir="$HOME/.local/bin"
  mkdir -p "$bin_dir"
  local scripts_dir src name dest current linked=0
  scripts_dir="$(runtime_scripts_dir)"
  for src in "$scripts_dir"/atelier-*; do
    [ -f "$src" ] || continue
    name="$(basename "$src")"
    dest="$bin_dir/$name"
    [ -x "$src" ] || chmod +x "$src"
    if [ -L "$dest" ]; then
      current="$(readlink "$dest")"
      [ "$current" = "$src" ] && continue
      ln -sfn "$src" "$dest"; sublog "updated symlink: $name"; linked=$((linked+1))
    elif [ -e "$dest" ]; then
      warn "$dest exists and is not a symlink — leaving it alone"
    else
      ln -s "$src" "$dest"; sublog "linked $name"; linked=$((linked+1))
    fi
  done
  if [ "$linked" -gt 0 ]; then log "re-symlinked $linked new/changed helper(s) into $bin_dir"; else sublog "helper symlinks already in sync"; fi
}

# Re-inject the shellrc hook block via install.sh's dedicated path (TASK_016).
# A pulled release — or simply an operator whose rc block drifted behind the
# clone — may need the PATH/env exports or task()/atelier() functions refreshed;
# atelier-update used to never touch the shellrc, forcing a full install re-run.
# Idempotent: install.sh --refresh-shellrc no-ops when the rc block version
# already matches. Runs on BOTH the pulled-update path and the no-commits resync
# path, so a clone that is current but an rc that is behind still converges.
refresh_shellrc_block() {
  [ -f "$PLUGIN_ROOT/install.sh" ] || return 0
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}" out
  out="$(bash "$PLUGIN_ROOT/install.sh" --config-dir "$cfg" --refresh-shellrc 2>&1 || true)"
  if printf '%s' "$out" | grep -qiE 'append|refresh'; then
    sublog "shellrc hook block updated — run \`exec zsh\` (or open a new terminal) to load it"
  else
    sublog "shellrc hook block already current"
  fi
}

# ---------- usage ----------
usage() {
  cat <<EOF
${SCRIPT_NAME} ${VERSION}

Update atelier to the latest release and refresh the installed artifacts
(versioned runtime dir, instantiated templates, helper symlinks) so Claude
Code sessions load the new version on next start. Managed installs (#39)
update via Claude Code's plugin cache; clone installs (legacy/dev) pull
origin/main.

USAGE:
  ${SCRIPT_NAME} [OPTIONS]

OPTIONS:
  --plugin-root <path>   Path to the atelier clone (legacy/dev flow).
                         Resolution order: this flag, then
                         \$ATELIER_PLUGIN_ROOT, then the source root this
                         script lives inside (resolved via readlink on the
                         symlink, then dirname). Flag/env paths must be a
                         git repository with an \`origin\` remote pointing
                         at AkaLab-Tech/atelier (or a fork thereof). When
                         the discovered root is the managed runtime dir
                         (#39 — no git clone on disk), the update runs via
                         \`claude plugin update\` + a runtime-dir swap
                         instead of git.
  --dry-run              Pull + classify + report, but do not re-instantiate
                         templates or invoke \`claude plugin update\`.
                         Useful to see what would change.
  --help, -h             Show this help and exit.

EXIT CODES:
  0   update applied (something changed)
  1   error (no clone, git pull failed, jq missing, ...)
  2   already up to date (no commits pulled)

NOTES:
  - settings.template.json changes are surfaced as a warning here; the
    permission-diff prompt + revert flow (M6.1.b) runs on the clone-mode
    pulled path. Managed mode backs up the previous instantiated copy.
  - Helper symlinks in ~/.local/bin/ resolve through the versioned runtime
    dir's \`current\` symlink (#39): a version swap updates every helper at
    once; this script re-links anything missing or still pointing at a
    clone / plugin cache.
  - \`claude plugin update\` refreshes Claude Code's plugin cache. Open
    sessions keep loading the old version until they restart.
EOF
}

# ---------- arg parse ----------
PLUGIN_ROOT_FLAG=""
DRY_RUN=false

while [ $# -gt 0 ]; do
  case "$1" in
    --plugin-root)
      [ -n "${2:-}" ] || die "--plugin-root requires a value"
      PLUGIN_ROOT_FLAG="$2"; shift 2 ;;
    --plugin-root=*) PLUGIN_ROOT_FLAG="${1#--plugin-root=}"; shift ;;
    --dry-run) DRY_RUN=true; shift ;;
    --help|-h) usage; exit 0 ;;
    *) die "unknown arg: $1 (run --help for usage)" ;;
  esac
done

# ---------- resolve source root (#39 F1) ----------
# Shared concept with install.sh's ATELIER_SOURCE_ROOT: the tree the
# installed helpers were sourced from. Two delivery modes exist —
#   clone   : a git repo (legacy/dev flow) → the git fetch/merge path below.
#   managed : the versioned runtime dir install.sh Phase C.1 populates
#             ($ATELIER_RUNTIME_DIR, default ~/.local/share/atelier), a
#             plain tree with no git metadata.
RUNTIME_BASE="${ATELIER_RUNTIME_DIR:-$HOME/.local/share/atelier}"

resolve_plugin_root() {
  # 1) explicit flag wins — legacy/dev clone flow, unchanged (#39 keeps
  #    --plugin-root as the explicit clone escape hatch).
  if [ -n "$PLUGIN_ROOT_FLAG" ]; then
    [ -d "$PLUGIN_ROOT_FLAG/.git" ] || die "--plugin-root '$PLUGIN_ROOT_FLAG' is not a git repo"
    printf '%s\n' "$PLUGIN_ROOT_FLAG"
    return
  fi

  # 2) env var — unchanged
  if [ -n "${ATELIER_PLUGIN_ROOT:-}" ]; then
    [ -d "$ATELIER_PLUGIN_ROOT/.git" ] || die "\$ATELIER_PLUGIN_ROOT '$ATELIER_PLUGIN_ROOT' is not a git repo"
    printf '%s\n' "$ATELIER_PLUGIN_ROOT"
    return
  fi

  # 3) script-relative discovery: this script is symlinked from ~/.local/bin/
  #    to <root>/scripts/atelier-update (where <root> is the clone pre-#39,
  #    or $RUNTIME_BASE/current/ → $RUNTIME_BASE/<version>/ post-#39).
  #    Resolve the symlink, then dirname twice. No .git requirement here —
  #    detect_update_mode() decides clone vs managed afterwards.
  local self real_path
  self="${BASH_SOURCE[0]}"
  if [ -L "$self" ]; then
    real_path="$(readlink -f "$self" 2>/dev/null || readlink "$self")"
  else
    real_path="$self"
  fi
  # real_path is now <root>/scripts/atelier-update; dirname × 2 → <root>
  local candidate; candidate="$(cd -P "$(dirname "$real_path")/.." && pwd)"
  if [ -f "$candidate/install.sh" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  die "could not resolve atelier source root (try --plugin-root <path> or set \$ATELIER_PLUGIN_ROOT)"
}

# detect_update_mode <root> — echo "clone" when the root is a git repo
# (covers worktrees too), "managed" when it is a plain tree under the
# versioned runtime dir, "unknown" otherwise. Compares against both the
# literal and the physical $RUNTIME_BASE path because <root> comes back
# symlink-resolved from resolve_plugin_root.
detect_update_mode() {
  local root="$1"
  if git -C "$root" rev-parse --git-dir >/dev/null 2>&1; then
    printf 'clone\n'
    return
  fi
  local base_physical
  base_physical="$(cd -P "$RUNTIME_BASE" 2>/dev/null && pwd || printf '%s' "$RUNTIME_BASE")"
  case "$root" in
    "$RUNTIME_BASE"|"$RUNTIME_BASE"/*|"$base_physical"|"$base_physical"/*)
      printf 'managed\n'
      return ;;
  esac
  printf 'unknown\n'
}

# ---------- runtime dir swap + managed update (#39 F4) ----------

# True (0) when the managed runtime dir's `current` symlink does not point at
# the version the source tree ships — the runtime lags the source, or was
# never materialized (pre-#39-F2 install). Used by the clone-mode no-commits
# path so clone installs also converge on the runtime dir.
runtime_out_of_sync() {
  local want="$1" have
  have="$(readlink "$RUNTIME_BASE/current" 2>/dev/null || true)"
  [ "$have" != "$want" ]
}

# Copy the runtime payload from source tree $1 into $RUNTIME_BASE/<version>/
# and atomically swap `current` (+ prune down to 2 retained versions).
# REUSES install.sh's F2 implementation (phase_c_1_runtime_dir with its
# staging+mv and prune helpers) by sourcing the install.sh the source tree
# itself ships — install.sh is main-gated, so sourcing only defines
# functions. Runs in a subshell so install.sh's own log/warn/die helpers and
# globals never leak into this script. Works from both a clone and a
# plugin-cache snapshot: both carry install.sh at their root.
runtime_swap_from_source() {
  local src="$1"
  [ -f "$src/install.sh" ] || die "cannot swap runtime dir: $src/install.sh missing (not an atelier tree?)"
  log "materializing runtime dir from $src"
  (
    export ATELIER_SOURCE_ROOT="$src"
    # shellcheck disable=SC1091
    source "$src/install.sh"
    resolve_source_root
    detect_source_mode
    phase_c_1_runtime_dir
  ) || die "runtime dir swap from $src failed"
}

# Managed-mode update (#39 F4): `claude plugin update` refreshes Claude
# Code's plugin cache (that IS the fetch step — no git), then the freshly
# cached version is copied into $RUNTIME_BASE/<version>/ and `current` is
# swapped. Always exits: 0 update applied / drift resynced, 2 already up to
# date, 1 unrecoverable.
managed_update() {
  local cfg="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  cfg="${cfg/#\~/$HOME}"
  local manifest="$cfg/plugins/installed_plugins.json"
  local current_version
  current_version="$(readlink "$RUNTIME_BASE/current" 2>/dev/null || true)"

  log "managed install — updating from Claude Code's plugin cache (no git)"
  sublog "config dir:  $cfg"
  sublog "runtime:     $RUNTIME_BASE (current: ${current_version:-<none>})"

  if $DRY_RUN; then
    local cached
    cached="$(read_cached_plugin_version)"
    log "DRY-RUN — would run \`claude plugin update atelier@akalab-tech\`, copy the cached version into $RUNTIME_BASE/<version>/ and swap current"
    sublog "cache is at ${cached:-unknown}; runtime current is at ${current_version:-<none>}"
    exit 0
  fi

  # 1) Let the claude CLI pull the latest release into its plugin cache.
  #    This replaces clone-mode's git fetch/merge; there is NO separate
  #    cache refresh after the swap (the CLI just did it — that's the
  #    point of managed mode). refresh_plugin_cache tolerates "already up
  #    to date" and network failures (warn + continue with what's cached).
  refresh_plugin_cache

  # 2) Resolve the ACTIVE cache version via installed_plugins.json — the
  #    claude CLI's own pointer file — never by globbing version dirs.
  [ -f "$manifest" ] \
    || die "$manifest not found — Claude Code has no record of the atelier plugin (re-run the bootstrap installer)"
  local install_path new_version
  install_path="$(jq -r '.plugins["atelier@akalab-tech"][0].installPath // empty' "$manifest" 2>/dev/null || true)"
  new_version="$(jq -r '.plugins["atelier@akalab-tech"][0].version // empty' "$manifest" 2>/dev/null || true)"
  [ -n "$install_path" ] || die "no installPath recorded for atelier@akalab-tech in $manifest"
  install_path="${install_path/#\~/$HOME}"
  [ -d "$install_path" ] || die "plugin cache dir '$install_path' (from $manifest) does not exist"
  if [ -z "$new_version" ]; then
    new_version="$(jq -r '.version // empty' "$install_path/.claude-plugin/plugin.json" 2>/dev/null || true)"
  fi
  [ -n "$new_version" ] || die "cannot determine the cached atelier version (no version in $manifest or the cached plugin.json)"
  sublog "cache:       $new_version ($install_path)"

  # 3) Same version → no swap needed; the drift checks below still run so
  #    templates/symlinks that lag the runtime converge (mirrors clone
  #    mode's no-commits resync path).
  local swapped=false
  if [ "$new_version" = "$current_version" ]; then
    log "runtime already at $new_version — checking installed artifacts for drift"
  else
    log "updating runtime: ${current_version:-<none>} → $new_version"
    runtime_swap_from_source "$install_path"
    swapped=true
  fi

  # 4) Point the shared refresh helpers at the runtime version dir — the
  #    managed equivalent of "the clone after git pull". Decoupled from the
  #    cache path on purpose: the runtime copy is atelier's own tree.
  PLUGIN_ROOT="$RUNTIME_BASE/$new_version"

  local tmpl_drift=false link_drift=false
  templates_out_of_sync && tmpl_drift=true || true
  symlinks_out_of_sync && link_drift=true || true

  if ! $swapped && ! $tmpl_drift && ! $link_drift; then
    log "already up to date — nothing to do"
    echo ""
    ok "version: $new_version (cache, runtime, templates and helper symlinks all in sync)"
    exit 2
  fi

  # 5) Converge the installed artifacts: instantiated templates (same
  #    function clone mode uses, now reading the new runtime dir), helper
  #    symlinks through current/, and the shellrc hook block.
  { $swapped || $tmpl_drift; } && refresh_instantiated_templates || true
  resync_script_symlinks
  refresh_shellrc_block

  echo ""
  if $swapped; then
    ok "update applied — runtime current -> $new_version; restart open Claude Code sessions to pick up agent/skill/command changes"
  else
    ok "installed artifacts resynced to $new_version"
  fi
  exit 0
}

# ---------- dependency check ----------
command -v git >/dev/null 2>&1 || die "git not found in PATH"
command -v jq >/dev/null 2>&1 || die "jq not found in PATH"
command -v claude >/dev/null 2>&1 \
  || warn "claude CLI not found in PATH; \`claude plugin update\` step will be skipped"

# ---------- start ----------
log "atelier-update ${VERSION}"

PLUGIN_ROOT="$(resolve_plugin_root)"
sublog "plugin-root: $PLUGIN_ROOT"

UPDATE_MODE="$(detect_update_mode "$PLUGIN_ROOT")"
if [ "$UPDATE_MODE" = "managed" ]; then
  # #39 F4 — cache-driven managed update: `claude plugin update` refreshes
  # the plugin cache, the new version is copied into $RUNTIME_BASE/<version>/
  # and `current` is swapped. managed_update never returns (exit 0/1/2).
  managed_update
fi
if [ "$UPDATE_MODE" != "clone" ]; then
  die "resolved root '$PLUGIN_ROOT' is neither a git clone nor a managed runtime dir under $RUNTIME_BASE (use --plugin-root <clone> or \$ATELIER_PLUGIN_ROOT)"
fi

# ---------- clone mode (legacy/dev) — unchanged below ----------

# Confirm remote points at the atelier repo (or a fork thereof). We accept
# any URL that ends with `atelier.git`, `atelier`, or `/atelier-*` — covers
# forks the operator might be running for their own customisations.
REMOTE_URL="$(git -C "$PLUGIN_ROOT" remote get-url origin 2>/dev/null || true)"
if [ -z "$REMOTE_URL" ]; then
  die "no 'origin' remote in $PLUGIN_ROOT — cannot pull"
fi
sublog "remote:      $REMOTE_URL"

# ---------- capture pre-pull state ----------
OLD_SHA="$(git -C "$PLUGIN_ROOT" rev-parse HEAD)"
OLD_VERSION="$(jq -r '.version' "$PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null || echo 'unknown')"
sublog "current:     $OLD_VERSION ($OLD_SHA)"

# Refuse to pull if the working tree is dirty — would risk a merge conflict
# that the operator did not opt into.
DIRTY="$(git -C "$PLUGIN_ROOT" status --porcelain)"
if [ -n "$DIRTY" ]; then
  warn "working tree has uncommitted changes:"
  printf '%s\n' "$DIRTY" | sed 's/^/      /' >&2
  die "commit or stash before running update"
fi

# Refuse on a non-main branch unless --plugin-root override is used and the
# branch is otherwise clean. Pulling on a feature branch with --ff-only and
# upstream=origin/main would diverge weirdly.
CURRENT_BRANCH="$(git -C "$PLUGIN_ROOT" rev-parse --abbrev-ref HEAD)"
if [ "$CURRENT_BRANCH" != "main" ]; then
  die "current branch is '$CURRENT_BRANCH'; atelier-update only operates on 'main' (switch with: git -C $PLUGIN_ROOT checkout main)"
fi

# ---------- pull ----------
log "pulling origin/main"
if ! git -C "$PLUGIN_ROOT" fetch --quiet origin main; then
  die "git fetch failed"
fi
if ! git -C "$PLUGIN_ROOT" merge --ff-only --quiet origin/main; then
  die "git merge --ff-only failed (clone has diverged from origin/main; reconcile manually)"
fi

NEW_SHA="$(git -C "$PLUGIN_ROOT" rev-parse HEAD)"
NEW_VERSION="$(jq -r '.version' "$PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null || echo 'unknown')"

if [ "$OLD_SHA" = "$NEW_SHA" ]; then
  # The clone is synced with origin/main, but the artifacts INSTALLED from it
  # can each lag independently: the plugin CACHE Claude Code loads, the
  # instantiated TEMPLATES setup-project reads, and the helper SYMLINKS in
  # ~/.local/bin. A direct `git pull`, a prior failed refresh, a session that
  # never restarted, or a release that added a helper all leave one of these
  # behind. Tying "nothing to do" to the clone SHA alone leaves that drift
  # uncorrectable by the tool meant to fix it (M7.1.F58 cache, F61 templates,
  # F60 symlinks). Detect each dimension; only declare done when ALL align.
  ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  CACHED_VERSION="$(read_cached_plugin_version)"
  cache_drift=false; tmpl_drift=false; link_drift=false; rt_drift=false
  [ "$CACHED_VERSION" != "$NEW_VERSION" ] && cache_drift=true || true
  templates_out_of_sync && tmpl_drift=true || true
  runtime_out_of_sync "$NEW_VERSION" && rt_drift=true || true
  symlinks_out_of_sync && link_drift=true || true

  if ! $cache_drift && ! $tmpl_drift && ! $link_drift && ! $rt_drift; then
    log "already up to date — nothing to do"
    echo ""
    ok "version: $NEW_VERSION (cache, runtime, templates and helper symlinks all in sync)"
    exit 2
  fi

  $cache_drift && warn "plugin cache is at ${CACHED_VERSION:-unknown}, clone is at $NEW_VERSION" || true
  $tmpl_drift  && warn "instantiated templates differ from the clone" || true
  $rt_drift    && warn "managed runtime dir lags the clone (current != $NEW_VERSION)" || true
  $link_drift  && warn "one or more helper symlinks are missing or stale" || true

  if $DRY_RUN; then
    log "DRY-RUN — would resync installed artifacts (no new commits to pull)"
    echo ""
    $cache_drift && ok "would refresh plugin cache: ${CACHED_VERSION:-unknown} → $NEW_VERSION" || true
    $tmpl_drift  && ok "would refresh instantiated templates" || true
    $rt_drift    && ok "would refresh the runtime dir + swap current -> $NEW_VERSION" || true
    $link_drift  && ok "would re-symlink helper scripts" || true
    exit 0
  fi

  log "resyncing installed artifacts (no new commits to pull)"
  # Runtime swap first — the symlink resync below routes through current/.
  $rt_drift    && runtime_swap_from_source "$PLUGIN_ROOT" || true
  $tmpl_drift  && refresh_instantiated_templates || true
  $cache_drift && refresh_plugin_cache || true
  resync_script_symlinks
  refresh_shellrc_block
  echo ""
  ok "installed artifacts resynced to $NEW_VERSION — restart open Claude Code sessions to pick up plugin/agent changes"
  exit 0
fi

sublog "pulled:      $NEW_VERSION ($NEW_SHA)"
sublog "commits:     $(git -C "$PLUGIN_ROOT" rev-list --count "$OLD_SHA..$NEW_SHA")"

# ---------- classify changed files ----------
log "classifying changed files"
CHANGED_FILES_RAW="$(git -C "$PLUGIN_ROOT" diff --name-only "$OLD_SHA..$NEW_SHA")"

# Buckets: scripts / templates / agents / skills / commands / hooks / docs / plugin / other
declare_buckets() {
  SCRIPTS=()
  TEMPLATES=()
  AGENTS=()
  SKILLS=()
  COMMANDS=()
  HOOKS=()
  DOCS=()
  PLUGIN_MANIFEST=()
  OTHER=()
}
declare_buckets

# Read each path and route it to a bucket. The classification mirrors how
# the operator thinks about the codebase, not raw directory layout.
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    scripts/*)              SCRIPTS+=("$f") ;;
    templates/*)            TEMPLATES+=("$f") ;;
    agents/*)               AGENTS+=("$f") ;;
    skills/*)               SKILLS+=("$f") ;;
    commands/*)             COMMANDS+=("$f") ;;
    hooks/*)                HOOKS+=("$f") ;;
    .claude-plugin/*)       PLUGIN_MANIFEST+=("$f") ;;
    install.sh|operator-rules.md|README.md|PLAN.md|HISTORY.md|ROADMAP.md|IN_PROGRESS.md|CLAUDE.md|docs/*)
      DOCS+=("$f") ;;
    *)                      OTHER+=("$f") ;;
  esac
done <<< "$CHANGED_FILES_RAW"

# Detect whether settings.template.json specifically changed — flag for the
# operator since M6.1.a does not render the permission diff yet.
SETTINGS_TEMPLATE_CHANGED=false
for f in ${TEMPLATES[@]+"${TEMPLATES[@]}"}; do
  [ "$f" = "templates/settings.template.json" ] && SETTINGS_TEMPLATE_CHANGED=true
done

# ---------- apply deltas (unless --dry-run) ----------
# Pre-declare APPLY_SETTINGS so the final report (after the if/else block)
# can read it under `set -u` even when --dry-run skips the branch that
# would otherwise set it.
APPLY_SETTINGS=true
if $DRY_RUN; then
  log "DRY-RUN — skipping template re-instantiation and plugin update"
else
  # 1) Re-instantiate templates in $ATELIER_CONFIG_DIR/templates/. The clone's
  #    install.sh has the canonical logic in phase_c_1_instantiate_templates;
  #    we sub-source it cleanly by re-running just that phase via a helper
  #    invocation. Simpler approach: invoke install.sh's helper directly
  #    once it is refactored to be callable; for now, replicate the small
  #    amount of substitution here.
  ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"
  if [ ! -d "$ATELIER_CONFIG_DIR/templates" ]; then
    warn "$ATELIER_CONFIG_DIR/templates does not exist — was install.sh ever run?"
    warn "skipping template refresh; re-run install.sh to bootstrap"
  else
    log "refreshing $ATELIER_CONFIG_DIR/templates/"

    # ---- settings.template.json with permission-diff prompt (M6.1.b) ----
    # When the new settings.template.json differs from the old one,
    # invoke atelier-permission-diff and prompt the operator before
    # applying. On N, the new template stays in the clone (the operator
    # may inspect / git-revert it) but $ATELIER_CONFIG_DIR is left
    # untouched, so the agent keeps operating under the old permission
    # set until the operator re-runs `atelier-update` and accepts.
    APPLY_SETTINGS=true
    if $SETTINGS_TEMPLATE_CHANGED; then
      # Extract the old settings.template.json from git history (pre-pull
      # state was OLD_SHA) so the diff has both versions on disk. We
      # compare the un-substituted templates (with <atelier-config-dir>
      # placeholders intact); the diff cares about the permission
      # patterns, not the operator's config dir path.
      TMP_OLD="$(mktemp -t atelier-update-old-settings.XXXXXX.json)"
      git -C "$PLUGIN_ROOT" show "$OLD_SHA:templates/settings.template.json" > "$TMP_OLD"

      # Try the helper first; fall back to the in-repo copy on path
      # mismatch (e.g., when the script is run before install.sh creates
      # the ~/.local/bin symlink for atelier-permission-diff).
      DIFF_TOOL="$(command -v atelier-permission-diff || true)"
      [ -z "$DIFF_TOOL" ] && DIFF_TOOL="$PLUGIN_ROOT/scripts/atelier-permission-diff"

      if [ -x "$DIFF_TOOL" ]; then
        # Run the diff. Exit 0 = no changes (shouldn't reach here, but
        # safe to handle). Exit 1 = changes rendered to stdout, prompt
        # the operator. Exit 2 = tool error; warn and apply anyway (the
        # alternative — refusing to update — is worse than missing
        # the diff).
        DIFF_RC=0
        "$DIFF_TOOL" --old "$TMP_OLD" --new "$PLUGIN_ROOT/templates/settings.template.json" || DIFF_RC=$?
        rm -f "$TMP_OLD"
        case "$DIFF_RC" in
          0) sublog "settings.template.json content changed but no permission diff (likely comment/whitespace only)" ;;
          1)
            if [ -t 0 ]; then
              printf "Apply these permission changes? [y/N]: " >&2
              read -r ans
              case "$ans" in
                y|Y|yes|Yes) sublog "operator confirmed — applying" ;;
                *)           APPLY_SETTINGS=false; sublog "operator declined — keeping old settings.template.json in \$ATELIER_CONFIG_DIR" ;;
              esac
            else
              # Non-interactive — refuse to apply silently. The operator
              # re-runs with a TTY to accept.
              APPLY_SETTINGS=false
              warn "non-interactive mode: refusing to apply permission changes without confirmation"
              warn "re-run \`atelier-update\` from an interactive shell to accept"
            fi
            ;;
          *) warn "atelier-permission-diff failed (rc=$DIFF_RC); applying new settings.template.json without diff" ;;
        esac
      else
        warn "atelier-permission-diff not found; applying new settings.template.json without diff"
        rm -f "$TMP_OLD"
      fi
    fi

    if $APPLY_SETTINGS; then
      sed "s|<atelier-config-dir>|$ATELIER_CONFIG_DIR|g" \
          "$PLUGIN_ROOT/templates/settings.template.json" \
          > "$ATELIER_CONFIG_DIR/templates/settings.template.json"
      sublog "refreshed settings.template.json"
    else
      sublog "preserved $ATELIER_CONFIG_DIR/templates/settings.template.json (operator declined)"
    fi

    # ---- project-claude.md.template (verbatim, no permissions) ----
    cp "$PLUGIN_ROOT/templates/project-claude.md.template" \
       "$ATELIER_CONFIG_DIR/templates/project-claude.md.template"
    sublog "refreshed project-claude.md.template"

    # ---- atelier.template.json (verbatim, added in M7.1.F27) ----
    if [ -f "$PLUGIN_ROOT/templates/atelier.template.json" ]; then
      cp "$PLUGIN_ROOT/templates/atelier.template.json" \
         "$ATELIER_CONFIG_DIR/templates/atelier.template.json"
      sublog "refreshed atelier.template.json"
    fi
  fi

  # 2) Trigger `claude plugin update` so Claude Code's plugin cache lands
  #    on the new version. Open sessions keep loading the old version
  #    until they restart — surface this in the final report. (Clone mode
  #    keeps this step; in managed mode the CLI update IS the fetch.)
  refresh_plugin_cache

  # 3) Refresh the managed runtime dir from the just-pulled clone and swap
  #    `current` (#39 F4) — must land before the symlink resync below,
  #    which routes every helper through $RUNTIME_BASE/current/scripts/.
  runtime_swap_from_source "$PLUGIN_ROOT"

  # 4) Re-symlink helper scripts (M7.1.F60). A pulled release may have added a
  #    new scripts/atelier-* helper; without this it would stay unlinked until
  #    the operator re-ran install.sh by hand.
  resync_script_symlinks

  # 5) Re-inject the shellrc hook block (TASK_016) — see refresh_shellrc_block.
  refresh_shellrc_block
fi

# ---------- report ----------
echo ""
log "atelier-update report"
sublog "version:     $OLD_VERSION → $NEW_VERSION"
sublog "commits:     $OLD_SHA..$NEW_SHA"
sublog ""
sublog "Changed by bucket:"
report_bucket() {
  local name="$1"; shift
  [ "$#" -eq 0 ] && return
  printf '      %s (%d):\n' "$name" "$#"
  printf '        %s\n' "$@"
}
# `${arr[@]+...}` guards against `set -u` tripping on empty arrays under
# bash 3.2 (macOS): expands to the elements when set, expands to nothing
# (no error) when empty.
report_bucket "scripts"   ${SCRIPTS[@]+"${SCRIPTS[@]}"}
report_bucket "templates" ${TEMPLATES[@]+"${TEMPLATES[@]}"}
report_bucket "agents"    ${AGENTS[@]+"${AGENTS[@]}"}
report_bucket "skills"    ${SKILLS[@]+"${SKILLS[@]}"}
report_bucket "commands"  ${COMMANDS[@]+"${COMMANDS[@]}"}
report_bucket "hooks"     ${HOOKS[@]+"${HOOKS[@]}"}
report_bucket "plugin"    ${PLUGIN_MANIFEST[@]+"${PLUGIN_MANIFEST[@]}"}
report_bucket "docs"      ${DOCS[@]+"${DOCS[@]}"}
report_bucket "other"     ${OTHER[@]+"${OTHER[@]}"}

if $SETTINGS_TEMPLATE_CHANGED; then
  echo ""
  if $APPLY_SETTINGS; then
    sublog "settings.template.json: applied (permission changes accepted)"
  else
    warn "settings.template.json: NOT applied — operator declined permission changes."
    warn "  - the clone has the new template; \$ATELIER_CONFIG_DIR/templates/ has the old one."
    warn "  - the agent will keep operating under the old permission set."
    warn "  - re-run \`atelier-update\` from an interactive shell to re-evaluate."
  fi
fi

echo ""
ok "update applied — restart open Claude Code sessions to pick up agent/skill/command changes"
exit 0
