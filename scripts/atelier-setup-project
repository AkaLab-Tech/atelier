#!/usr/bin/env bash
#
# atelier-setup-project — bootstrap a project directory so atelier can manage
# tasks in it. Runs OUTSIDE the Claude Code session to sidestep the harness's
# interactive `.claude/**` Write/Edit guard that breaks `claude -p` mode.
# See HISTORY.md → M4.7 (per-task settings) and M4.9 (this script).
#
# Mirrors the spec in commands/setup-project.md. The slash command is a thin
# wrapper that invokes this script via Bash(atelier-setup-project:*).
#
# Usage:
#   atelier-setup-project [--plugin-root <path>] [--yes|-y] [<project-path>]
#   atelier-setup-project --help
#
# Exit codes:
#   0  success (created, updated, or preserved)
#   1  unrecoverable error (missing template, bad path, json corruption)
#   2  refusal (already configured + non-interactive, or operator declined)

set -euo pipefail
IFS=$'\n\t'

VERSION="0.1.0"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

# ---------- logging (mirrors install.sh style) ----------
log()    { printf '==> %s\n' "$*"; }
sublog() { printf '    %s\n' "$*"; }
warn()   { printf '!!  %s\n' "$*" >&2; }
die()    { printf '!!  ERROR: %s\n' "$*" >&2; exit 1; }
ok()     { printf '    OK: %s\n' "$*"; }

# ---------- usage ----------
usage() {
  cat <<EOF
atelier-setup-project ${VERSION}

Bootstrap a project so atelier can manage tasks in it. Idempotent.

USAGE:
  ${SCRIPT_NAME} [OPTIONS] [<project-path>]
  ${SCRIPT_NAME} --per-task-settings <absolute-worktree-path> [--plugin-root <path>]

OPTIONS:
  --plugin-root <path>   Path to the atelier plugin root (containing
                         templates/ and .claude-plugin/plugin.json).
                         Resolution order: this flag, then
                         \$ATELIER_PLUGIN_ROOT, then the atelier checkout
                         this script lives in, then the first match under
                         \$ATELIER_CONFIG_DIR/plugins/*/atelier/
                         (default \$ATELIER_CONFIG_DIR is ~/.claude-work/).
  --yes, -y              Non-interactive mode. Auto-resolves every prompt
                         with the safe default (never overwrite, never
                         weaken). Also honored if \$ATELIER_AUTO is set.
  --skip-policy          Skip the interactive decision-policy step (M4.26.b).
                         The .atelier.json keeps the template's conservative
                         defaults (every category falls back to "ask").
                         Run /atelier:set-policy later to configure.
  --mode <new|existing>  Force the project-mode detection (M4.19) used
                         by the /setup-project slash command to decide
                         whether to interview the operator (new) or
                         scan the codebase (existing). Default is the
                         heuristic — 0 commits / docs-only files → new,
                         manifest files / populated src/ / >3 tracked
                         files → existing.
  --per-task-settings <abs-path>
                         Per-task mode (used by /next-task step 7). Skips
                         the full project bootstrap; only writes
                         <abs-path>/.claude/settings.json from the
                         instantiated template, substituting <worktree>
                         with <abs-path>. Always overwrites — worktrees
                         are ephemeral, each invocation produces a fresh
                         deterministic file. Mutually exclusive with the
                         <project-path> positional argument. --yes /
                         \$ATELIER_AUTO are accepted but ignored
                         (per-task mode is non-interactive by construction).
  --help, -h             Show this help and exit.

POSITIONAL:
  <project-path>         Project root to set up. Defaults to current dir.

EXIT CODES:
  0   success (created, updated, or preserved)
  1   unrecoverable error
  2   refusal (already configured + non-interactive, or operator declined)
EOF
}

# ---------- arg parse ----------
PROJECT_PATH_ARG=""
PLUGIN_ROOT_FLAG=""
PER_TASK_SETTINGS_PATH=""
MODE_OVERRIDE=""           # M4.19: --mode=new|existing forces detection
SKIP_POLICY=false          # M4.26.b: --skip-policy skips the interactive decision-policy step
NONINTERACTIVE=false
[ -n "${ATELIER_AUTO:-}" ] && NONINTERACTIVE=true

while [ $# -gt 0 ]; do
  case "$1" in
    --plugin-root)
      # M7.1.F18: tolerate empty value (treat as "flag not given") so callers
      # who do `--plugin-root "$CLAUDE_PLUGIN_ROOT"` from inside a slash
      # command — where Claude Code does NOT auto-set CLAUDE_PLUGIN_ROOT —
      # don't die on the empty expansion. The fallback chain in
      # resolve_plugin_root() picks up via $ATELIER_PLUGIN_ROOT or
      # script-relative discovery.
      PLUGIN_ROOT_FLAG="${2:-}"; shift 2 ;;
    --plugin-root=*)
      PLUGIN_ROOT_FLAG="${1#--plugin-root=}"; shift ;;
    --per-task-settings)
      [ -n "${2:-}" ] || die "--per-task-settings requires an absolute worktree path"
      PER_TASK_SETTINGS_PATH="$2"; shift 2 ;;
    --per-task-settings=*)
      PER_TASK_SETTINGS_PATH="${1#--per-task-settings=}"; shift ;;
    --mode)
      [ -n "${2:-}" ] || die "--mode requires a value: new or existing"
      MODE_OVERRIDE="$2"; shift 2 ;;
    --mode=*)
      MODE_OVERRIDE="${1#--mode=}"; shift ;;
    --yes|-y)
      NONINTERACTIVE=true; shift ;;
    --skip-policy)
      # M4.26.b: skip the interactive decision-policy prompt. Useful for
      # automation that does not want to walk the operator through each
      # catalog category. The .atelier.json keeps the template's
      # conservative defaults (decisionPolicy.default = "ask",
      # byCategory = {}). The operator can revise later with
      # /atelier:set-policy.
      SKIP_POLICY=true; shift ;;
    --help|-h)
      usage; exit 0 ;;
    --)
      shift; break ;;
    -*)
      die "unknown option: $1 (try --help)" ;;
    *)
      [ -z "$PROJECT_PATH_ARG" ] || die "only one project path may be given"
      PROJECT_PATH_ARG="$1"; shift ;;
  esac
done

# ---------- validate --mode value ----------
if [ -n "$MODE_OVERRIDE" ]; then
  case "$MODE_OVERRIDE" in
    new|existing) ;;
    *) die "--mode must be 'new' or 'existing', got '$MODE_OVERRIDE'" ;;
  esac
fi

# ---------- mutual exclusion: --per-task-settings is its own mode ----------
# Per-task mode is non-interactive by construction. --yes / $ATELIER_AUTO
# are accepted (and silently ignored) so chains that export ATELIER_AUTO
# globally don't need to unset it before invoking step 7.
if [ -n "$PER_TASK_SETTINGS_PATH" ]; then
  [ -z "$PROJECT_PATH_ARG" ] \
    || die "--per-task-settings is mutually exclusive with <project-path> positional argument"
fi

# ---------- required tools ----------
for tool in jq sed mkdir grep date; do
  command -v "$tool" >/dev/null 2>&1 || die "required tool '$tool' not found on PATH"
done

# ---------- script real path (for plugin-root discovery step 3) ----------
script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    local d
    d="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ $src != /* ]] && src="$d/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

looks_like_plugin_root() {
  [ -f "$1/templates/settings.template.json" ] \
    && [ -f "$1/.claude-plugin/plugin.json" ]
}

# ---------- plugin root resolution ----------
resolve_plugin_root() {
  local candidate

  if [ -n "$PLUGIN_ROOT_FLAG" ]; then
    candidate="$PLUGIN_ROOT_FLAG"
    looks_like_plugin_root "$candidate" \
      || die "--plugin-root '$candidate' is not an atelier checkout (missing templates/settings.template.json or .claude-plugin/plugin.json)"
    printf '%s\n' "$candidate"; return
  fi

  if [ -n "${ATELIER_PLUGIN_ROOT:-}" ]; then
    candidate="$ATELIER_PLUGIN_ROOT"
    looks_like_plugin_root "$candidate" \
      || die "\$ATELIER_PLUGIN_ROOT='$candidate' is not an atelier checkout"
    printf '%s\n' "$candidate"; return
  fi

  # Script-relative: ~/.local/bin/atelier-setup-project -> <atelier>/scripts/atelier-setup-project
  # script_dir returns <atelier>/scripts, so the parent is <atelier>.
  candidate="$(dirname "$(script_dir)")"
  if looks_like_plugin_root "$candidate"; then
    printf '%s\n' "$candidate"; return
  fi

  # Marketplace install: $ATELIER_CONFIG_DIR/plugins/<marketplace>/atelier/
  # (per M5.0 + M5.0.2; default $ATELIER_CONFIG_DIR is ~/.claude-work/).
  for candidate in "$ATELIER_CONFIG_DIR/plugins"/*/atelier; do
    if looks_like_plugin_root "$candidate"; then
      printf '%s\n' "$candidate"; return
    fi
  done

  die "cannot locate the atelier plugin root.

   Tried (in order):
   - --plugin-root flag         (not given)
   - \$ATELIER_PLUGIN_ROOT      (${ATELIER_PLUGIN_ROOT:-unset})
   - script-relative discovery  ($(dirname "$(script_dir)"))
   - \$ATELIER_CONFIG_DIR/plugins/*/atelier (no match, $ATELIER_CONFIG_DIR)

   Pass --plugin-root /abs/path/to/atelier-checkout, export ATELIER_PLUGIN_ROOT,
   or install via the atelier marketplace."
}

# ---------- project path validation ----------
resolve_project_path() {
  local input="${PROJECT_PATH_ARG:-.}"
  local abs

  if [ -d "$input" ]; then
    abs="$(cd "$input" && pwd -P)"
  elif [ -e "$input" ]; then
    die "<project-path> '$input' exists but is not a directory"
  else
    if $NONINTERACTIVE; then
      die "<project-path> '$input' does not exist.
   Non-interactive mode refuses to create the directory (operator intent ambiguous).
   Re-run interactively, or pre-create the directory first."
    fi
    printf "Directory '%s' does not exist. Create it? [y/N]: " "$input" >&2
    local ans; read -r ans
    case "$ans" in
      y|Y|yes|Yes) mkdir -p "$input" ;;
      *) die "operator declined directory creation" ;;
    esac
    abs="$(cd "$input" && pwd -P)"
  fi

  # Deny system roots as literals, and the subtrees that are unambiguously
  # system-owned (/etc, /usr, /Applications). Leave /var/* and /private/*
  # subtrees alone because that is where macOS tmpdirs (mktemp -d) live, and
  # smoke-testing the bootstrap there is legitimate.
  case "$abs" in
    "$HOME"|/|/bin|/sbin|/var|/opt|/private)
      die "refusing to set up atelier under '$abs' (system / home root)" ;;
    /etc|/etc/*|/usr|/usr/*|/Applications|/Applications/*)
      die "refusing to set up atelier under '$abs' (system directory)" ;;
  esac

  if [ "$abs" = "$PLUGIN_ROOT" ]; then
    die "refusing to set up atelier under its own plugin root '$abs'"
  fi

  printf '%s\n' "$abs"
}

# ---------- atelier config dir (M5.0 + M5.0.2) ----------
# Atelier's isolated Claude config root. install.sh bakes the chosen path
# into the shellrc hook block (`export ATELIER_CONFIG_DIR=...`) so any shell
# sourcing the rc inherits it. When this script runs from a non-atelier
# shell (e.g. a freshly-spawned `claude -p` subprocess that didn't read the
# rc, or the operator invoking the binary directly without a re-sourced
# shell), fall back to the default. Operators with a non-default config
# dir need either a re-sourced shell or to set ATELIER_CONFIG_DIR
# explicitly in the invocation env.
ATELIER_CONFIG_DIR="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}"

# ---------- idempotence ----------
CONFIG_FILE="$ATELIER_CONFIG_DIR/projects.json"

is_configured() {
  local proj="$1"
  [ -f "$CONFIG_FILE" ] || return 1
  jq -e --arg p "$proj" '.projects[$p] // empty' "$CONFIG_FILE" >/dev/null 2>&1
}

# ---------- step status (one variable per step for the final summary) ----------
SETTINGS_STATUS=""
ATELIER_CONFIG_STATUS=""
POLICY_STATUS=""             # M4.26.b: set by step_decision_policy
ROADMAP_STATUS=""
INPROGRESS_STATUS=""
HISTORY_STATUS=""
CLAUDE_STATUS=""
NPMRC_STATUS=""
GITIGNORE_STATUS=""
CONFIG_STATUS=""
SETUP_COMPLETED=""
SETUP_VERSION=""
DETECTED_MODE=""           # set by detect_project_mode (new|existing) — M4.19
ROOT_CLAUDE_MD_STATUS=""   # set by step_root_claude_md_detect (missing|present) — M4.19
TRACKING_LAYOUT_STATUS=""  # set by detect_tracking_layout (created|preserved-empty|preserved-nonempty) — M7.1.F50

# ---------- M4.19: detect project mode (new vs existing) ----------
# Bash side does detection ONLY. Drafting the root CLAUDE.md (AI work)
# happens in the /setup-project slash command, which dispatches the
# `project-profiler` agent based on the mode this function returns.
#
# Heuristic per the M4.19 ROADMAP entry:
#   new       — repo has 0 commits, OR tracks <=3 files all docs-only
#               (README*, LICENSE*, .gitignore).
#   existing  — repo has any manifest file (package.json, go.mod,
#               Cargo.toml, pyproject.toml, Gemfile, build.gradle*,
#               composer.json, requirements*.txt, mix.exs), OR a
#               populated source dir (src/, lib/, app/), OR >3 tracked
#               files.
#
# CLI override: --mode=new|existing forces the result and skips the
# heuristic. MODE_OVERRIDE is set by arg parse.
detect_project_mode() {
  local p="$1"

  if [ -n "$MODE_OVERRIDE" ]; then
    printf '%s\n' "$MODE_OVERRIDE"
    return
  fi

  # If the project isn't a git repo, treat as `new` — the operator
  # hasn't even initialised yet.
  if [ ! -d "$p/.git" ] && ! git -C "$p" rev-parse --git-dir >/dev/null 2>&1; then
    printf 'new\n'
    return
  fi

  # Count commits. 0 commits → new.
  local commit_count
  commit_count="$(git -C "$p" rev-list --count HEAD 2>/dev/null || echo 0)"
  if [ "$commit_count" = "0" ]; then
    printf 'new\n'
    return
  fi

  # Look for manifest files at the project root → existing.
  for manifest in package.json go.mod Cargo.toml pyproject.toml Gemfile build.gradle build.gradle.kts composer.json mix.exs; do
    if [ -f "$p/$manifest" ]; then
      printf 'existing\n'
      return
    fi
  done
  # requirements*.txt is glob, handle separately
  for f in "$p"/requirements*.txt; do
    if [ -f "$f" ]; then
      printf 'existing\n'
      return
    fi
  done

  # Populated source dir → existing.
  for d in src lib app; do
    if [ -d "$p/$d" ] && [ -n "$(ls -A "$p/$d" 2>/dev/null)" ]; then
      printf 'existing\n'
      return
    fi
  done

  # Count tracked files. >3 → existing. <=3 of docs-only patterns → new.
  local tracked_count
  tracked_count="$(git -C "$p" ls-files | wc -l | tr -d ' ')"
  if [ "$tracked_count" -gt 3 ]; then
    printf 'existing\n'
    return
  fi

  # 1..3 tracked files. Check they all match docs-only patterns.
  local non_docs_found=0
  while IFS= read -r f; do
    case "$f" in
      README*|LICENSE*|.gitignore) ;;
      *) non_docs_found=1; break ;;
    esac
  done < <(git -C "$p" ls-files)

  if [ "$non_docs_found" = "0" ]; then
    printf 'new\n'
  else
    printf 'existing\n'
  fi
}

# ---------- M4.19: detect root CLAUDE.md presence ----------
# Idempotent — the slash command reads this status. If `present`, the
# AI-drafting branch is skipped entirely (never overwrite operator's
# customizations).
detect_root_claude_md() {
  local p="$1"
  if [ -f "$p/CLAUDE.md" ]; then
    printf 'present\n'
  else
    printf 'missing\n'
  fi
}

# ---------- M7.1.F50: detect IN_PROGRESS.md tracking layout ----------
# Bash side emits a signal ONLY. The /setup-project slash command reads
# IN_PROGRESS.md when this returns `preserved-nonempty`, decides whether the
# content is a legit single active task vs a legacy multi-phase tracker, and
# offers /adopt-roadmap (claude-roadmap-tools) for the legacy case.
#
# Outcomes:
#   created             — the file was created fresh this run (canonical empty
#                         slot by construction). Nothing to adopt.
#   preserved-empty     — pre-existed and carries no task-like content (header
#                         / workflow prose only). Already canonical.
#   preserved-nonempty  — pre-existed and carries task-like content: any
#                         checkbox line (`- [ ]` / `- [x]`) or any `##` section
#                         heading. Could be a legit single active task OR a
#                         legacy phase tracker — the slash command disambiguates.
detect_tracking_layout() {
  local f="$PROJECT/IN_PROGRESS.md"

  if [ "$INPROGRESS_STATUS" = "created" ]; then
    printf 'created\n'
    return
  fi
  [ -f "$f" ] || { printf 'created\n'; return; }

  if grep -Eq '^[[:space:]]*-[[:space:]]+\[[ xX]\]' "$f" || grep -Eq '^##[[:space:]]' "$f"; then
    printf 'preserved-nonempty\n'
  else
    printf 'preserved-empty\n'
  fi
}

# ---------- helpers used by step_settings_json (M7.1.F26) ----------
# Detect whether $1 looks like an atelier-managed settings.json. Heuristic:
# top-level .permissions.defaultMode == "acceptEdits" AND .permissions.deny
# contains the distinctive "Bash(git push --force*)" entry from the template.
# Robust against operator edits to the allow list (those don't touch these
# two markers) while still catching pre-atelier or hand-rolled files.
is_atelier_managed_settings() {
  local f="$1"
  [ -f "$f" ] || return 1
  jq -e '
    (.permissions.defaultMode // "") == "acceptEdits"
    and ((.permissions.deny // []) | index("Bash(git push --force*)") != null)
  ' "$f" >/dev/null 2>&1
}

# Copy $1 to "$1.bak.<utc-timestamp>" and echo the backup path on stdout.
# Caller is expected to log the path; this function does not log to stderr
# so it composes inside command substitutions.
backup_with_timestamp() {
  local f="$1"
  local ts; ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
  local bak="${f}.bak.${ts}"
  cp "$f" "$bak" || die "failed to backup $f to $bak"
  printf '%s\n' "$bak"
}

# ---------- step 3: .claude/settings.json ----------
step_settings_json() {
  local target="$PROJECT/.claude/settings.json"
  # Read the INSTANTIATED template from atelier's config dir (per M5.0.2):
  # install.sh has already substituted <atelier-config-dir> in this copy,
  # so the only remaining placeholder is <worktree>. Reading from
  # $CLAUDE_PLUGIN_ROOT/templates/ here would pick up the source template
  # with the install-time placeholder unsubstituted.
  local template="$ATELIER_CONFIG_DIR/templates/settings.template.json"

  [ -f "$template" ] || die "template missing: $template"

  mkdir -p "$PROJECT/.claude"

  # Decide should_write / needs_backup before building the new file.
  # Three outcomes for SETTINGS_STATUS: created | updated | preserved.
  local should_write=false
  local needs_backup=false

  if [ ! -f "$target" ]; then
    # No existing file — straightforward create.
    should_write=true
  elif $RECONFIGURE; then
    # Reconfigure path: operator already confirmed "Re-run setup" upstream.
    # Compare current file against the instantiated template; only prompt
    # when they actually differ.
    local tmp_probe; tmp_probe="$(mktemp)"
    sed "s|<worktree>|$PROJECT|g" "$template" > "$tmp_probe" \
      || { rm -f "$tmp_probe"; die "sed substitution failed while probing $target"; }
    if diff -q "$target" "$tmp_probe" >/dev/null 2>&1; then
      rm -f "$tmp_probe"
      SETTINGS_STATUS="preserved"
      return
    fi
    rm -f "$tmp_probe"

    if $NONINTERACTIVE; then
      SETTINGS_STATUS="preserved"
      warn "$target has local edits — preserved (non-interactive default)"
      return
    fi
    printf "%s has local edits. Overwrite with current template (existing file will be backed up)? [y/N]: " "$target" >&2
    local ans; read -r ans
    case "$ans" in
      y|Y|yes|Yes) should_write=true; needs_backup=true ;;
      *)           SETTINGS_STATUS="preserved"; return ;;
    esac
  else
    # Target exists, NOT in reconfigure flow.
    if is_atelier_managed_settings "$target"; then
      # Atelier-managed: compare against the instantiated template and
      # auto-resync if drifted (M7.1.F38). Before F38 this path silently
      # preserved the existing file — which meant a freshly added allow /
      # deny / ask entry (e.g. F37's Bash(git wt*)) stayed trapped in
      # $ATELIER_CONFIG_DIR/templates/ for every operator who didn't also
      # delete <project>/.claude/settings.json by hand. Auto-resync with
      # backup restores the design intent: re-running setup-project on a
      # registered project picks up the current template. Operators with
      # local customisations recover them from the .bak file.
      local tmp_probe; tmp_probe="$(mktemp)"
      sed "s|<worktree>|$PROJECT|g" "$template" > "$tmp_probe" \
        || { rm -f "$tmp_probe"; die "sed substitution failed while probing $target"; }
      if diff -q "$target" "$tmp_probe" >/dev/null 2>&1; then
        rm -f "$tmp_probe"
        SETTINGS_STATUS="preserved"
        sublog "$target already exists (atelier-managed, in sync with template) — preserving"
        return
      fi
      rm -f "$tmp_probe"
      warn "$target has drifted from the current plugin template — auto-resyncing"
      warn "(existing file will be backed up; if you had local customisations, recover them from the .bak file)"
      should_write=true
      needs_backup=true
    else
      # Non-atelier-managed (legacy pre-atelier settings.json, or hand-rolled).
      # Prompt before silently keeping the file, because preserving silently
      # was the M7.1.F26 bug — operators ran /atelier:setup-project, the
      # script reported success, and then Claude Code still asked for
      # permission for every command because the template's acceptEdits +
      # allowlist never made it onto disk.
      warn "$target exists but is not atelier-managed"
      warn "(missing atelier's defaultMode=acceptEdits and/or distinctive deny entries)."
      warn "Likely a pre-atelier settings.json or a hand-edited file."

      if $NONINTERACTIVE; then
        SETTINGS_STATUS="preserved"
        warn "Preserving (non-interactive default). Re-run interactively to overwrite."
        return
      fi

      printf "Overwrite with current atelier template (existing file will be backed up)? [y/N]: " >&2
      local ans; read -r ans
      case "$ans" in
        y|Y|yes|Yes) should_write=true; needs_backup=true ;;
        *)
          SETTINGS_STATUS="preserved"
          sublog "Operator declined — preserving existing $target"
          return ;;
      esac
    fi
  fi

  $should_write || { SETTINGS_STATUS="preserved"; return; }

  # Build the instantiated template.
  local tmp; tmp="$(mktemp)"
  # Only <worktree> is substituted here — it's a per-project value. The
  # install-time placeholder <atelier-config-dir> was already substituted
  # by install.sh into the instantiated template at
  # $ATELIER_CONFIG_DIR/templates/ (M5.0.2). If <atelier-config-dir> is
  # still in the template at this point, that's an install bug, not a
  # runtime concern — surface it explicitly via the second grep check below.
  sed "s|<worktree>|$PROJECT|g" "$template" > "$tmp" \
    || { rm -f "$tmp"; die "sed substitution failed for $target"; }

  jq empty "$tmp" >/dev/null 2>&1 \
    || { rm -f "$tmp"; die "$template did not produce valid JSON after substitution"; }

  if grep -q "<worktree>" "$tmp"; then
    rm -f "$tmp"
    die "$template still contains literal '<worktree>' after substitution — template bug"
  fi
  if grep -q "<atelier-config-dir>" "$tmp"; then
    rm -f "$tmp"
    die "$template still contains literal '<atelier-config-dir>' — install.sh did not instantiate the template under \$ATELIER_CONFIG_DIR/templates/ (re-run install.sh)"
  fi

  if $needs_backup; then
    local bak; bak="$(backup_with_timestamp "$target")"
    sublog "Backed up existing settings.json to: $bak"
    mv "$tmp" "$target"
    SETTINGS_STATUS="updated"
  else
    mv "$tmp" "$target"
    SETTINGS_STATUS="created"
  fi
}

# ---------- step 3.5: .atelier.json (per-project atelier config) ----------
# Creates <project>/.atelier.json from the bundled template when missing.
# NEVER overwrites once it exists — this file is operator-owned after
# creation (M7.1.F27). To reset to defaults, the operator deletes the
# file and re-runs setup-project.
#
# The template lives at $ATELIER_CONFIG_DIR/templates/atelier.template.json
# (install.sh copies it from the plugin's templates/ at install time —
# same convention as settings.template.json).
step_atelier_config_json() {
  local target="$PROJECT/.atelier.json"
  local template="$ATELIER_CONFIG_DIR/templates/atelier.template.json"

  if [ ! -f "$template" ]; then
    # Older install that predates F27 — template not bundled yet. Don't
    # fail the setup; just skip and warn so the operator can re-run
    # install.sh to pick it up. atelier-pr-size-check uses built-in
    # defaults when the file is missing, so the absence is non-fatal.
    ATELIER_CONFIG_STATUS="skipped (template missing — re-run install.sh)"
    return
  fi

  if [ -f "$target" ]; then
    ATELIER_CONFIG_STATUS="preserved"
    return
  fi

  cp "$template" "$target" \
    || die "failed to write $target"

  jq empty "$target" >/dev/null 2>&1 \
    || die "$template did not produce valid JSON at $target"

  ATELIER_CONFIG_STATUS="created"
}

# ---------- step 3.6: decision policy (M4.26.b + M7.1.F46) ----------
# Walks the operator through each category in the decision-broker catalog
# and writes their per-category answer to <project>/.atelier.json's
# decisionPolicy.byCategory block. Runs when:
#   - $SKIP_POLICY is false (default)
#   - $NONINTERACTIVE is false (interactive mode required)
#   - The .atelier.json file exists AND either:
#       (a) ATELIER_CONFIG_STATUS == "created" — fresh file from this run, OR
#       (b) ATELIER_CONFIG_STATUS == "preserved" AND the file lacks the
#           decisionPolicy block entirely (M7.1.F46 — covers operators who
#           created .atelier.json before M4.26.b shipped). The block is
#           initialized to {"default": "ask", "byCategory": {}} before the
#           prompts run.
#   - The catalog file is readable under $PLUGIN_ROOT/agents/decision-broker/
#
# Preserved files that ALREADY have a decisionPolicy block are NOT re-prompted
# — the operator has their answers and revisions go through /atelier:set-policy.
#
# Per category, the operator chooses one of:
#   [a] Auto    — broker decides per-case (uses Haiku/Sonnet/Opus per riskLevel)
#   [f] Fix     — always pick the catalog's default option without thinking
#   [s] Ask     — atelier asks the operator each time (current behavior)
#
# The choice writes into decisionPolicy.byCategory.<category>:
#   "auto"    → the broker dispatches to the right-risk-tier evaluator agent
#   "<id>"    → fixed option id from the catalog (when operator picks [f])
#   "ask"    → no entry written; falls through to decisionPolicy.default
#              (which is "ask" by the template); semantically equivalent to
#              "ask" without bloating the file.
step_decision_policy() {
  POLICY_STATUS="skipped"

  if $SKIP_POLICY; then
    POLICY_STATUS="skipped (--skip-policy)"
    return
  fi
  if $NONINTERACTIVE; then
    POLICY_STATUS="skipped (non-interactive)"
    return
  fi
  # M7.1.F47: detect non-TTY contexts (e.g. invoked from the /atelier:setup-project
  # slash command via the Claude session's `Bash` tool, which spawns the binary
  # without an attached terminal). The prompt loop below requires `read` from a
  # TTY; running it without one either silently EOFs every prompt (bad: writes
  # nothing useful) or crashes under `set -u` (worse). Skip cleanly here and
  # tell the operator that /atelier:set-policy is the right surface for this
  # context — that command IS interactive even inside a Claude session because
  # it uses AskUserQuestion rather than `read`.
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    POLICY_STATUS="skipped (no TTY — run /atelier:set-policy from a Claude session to configure)"
    return
  fi

  local target="$PROJECT/.atelier.json"

  # F46: decide whether to run the prompts based on (config-status, block-present).
  # M4.26.b only ran when ATELIER_CONFIG_STATUS=="created", which silently
  # locked out operators whose .atelier.json predated M4.26.b — F38's drift
  # detector preserves the existing file and step_decision_policy then bailed
  # out without ever adding the block. F46 routes preserved-but-missing-block
  # into the prompts path with an explicit initialization.
  case "$ATELIER_CONFIG_STATUS" in
    created)
      # Fresh file from this run; the template already shipped the block.
      # Run prompts to fill it in.
      :
      ;;
    preserved)
      if [ ! -f "$target" ]; then
        POLICY_STATUS="skipped ($target missing despite preserved status)"
        return
      fi
      if jq -e '.decisionPolicy' "$target" >/dev/null 2>&1; then
        # Operator already has the block; revisions go through
        # /atelier:set-policy to avoid surprising them on re-runs.
        POLICY_STATUS="skipped (.atelier.json preserved, decisionPolicy already present)"
        return
      fi
      # F46 path: preserved file lacks the block. Initialize it with the
      # template's defaults before prompting so the prompts can write into
      # byCategory and decisionPolicy.default is set to "ask" up front
      # (consumed by the broker for unlisted categories).
      local init_tmp
      init_tmp="$(mktemp)"
      jq '. + {decisionPolicy: {default: "ask", byCategory: {}}}' "$target" > "$init_tmp" \
        && mv "$init_tmp" "$target" \
        || { rm -f "$init_tmp"; die "F46: failed to initialize decisionPolicy block in $target"; }
      sublog "F46: initialized decisionPolicy block in pre-M4.26.b $target"
      ;;
    *)
      # Template missing, or some other non-created/non-preserved status.
      # Nothing meaningful to prompt about.
      POLICY_STATUS="skipped (.atelier.json $ATELIER_CONFIG_STATUS)"
      return
      ;;
  esac

  local catalog="$PLUGIN_ROOT/agents/decision-broker/catalog.json"
  if [ ! -f "$catalog" ]; then
    POLICY_STATUS="skipped (catalog missing at $catalog — re-run install.sh)"
    return
  fi
  if ! jq -e '.categories | type == "object"' "$catalog" >/dev/null 2>&1; then
    POLICY_STATUS="skipped (catalog malformed at $catalog)"
    return
  fi

  if [ ! -f "$target" ]; then
    # Defensive: the file should exist at this point per the case above.
    POLICY_STATUS="skipped ($target missing)"
    return
  fi

  log "Decision policy (M4.26)"
  sublog "for each strategic decision atelier may face, choose how it should be handled:"
  sublog "  [a] Auto  — atelier decides per-case (uses an evaluator agent)"
  sublog "  [f] Fix   — always use the recommended default (no thinking)"
  sublog "  [s] Ask   — atelier asks you each time (current behavior, conservative)"

  # jq -r '.categories | keys[]' emits category ids in key order. bash 3.2
  # cannot use mapfile/readarray; iterate via process substitution.
  local category
  while IFS= read -r category; do
    local description default risk model
    description="$(jq -r --arg c "$category" '.categories[$c].description' "$catalog")"
    default="$(jq -r --arg c "$category" '.categories[$c].default' "$catalog")"
    risk="$(jq -r --arg c "$category" '.categories[$c].riskLevel' "$catalog")"
    model="$(jq -r --arg c "$category" '.categories[$c].model' "$catalog")"

    printf '\n'
    # M7.1.F47: the script does not export _C_BOLD/_C_RESET (those live in
    # install.sh). Plain printf is enough; the per-category structure (blank
    # line + indented category name + indented description + indented metadata
    # + indented prompt) reads cleanly without color emphasis. Operators on a
    # color-capable TTY would have liked the bold, but losing it is cheaper
    # than the original unbound-variable crash this step shipped with.
    printf '  %s\n' "$category"
    # Word-wrap the description in a basic way: print as-is; the operator
    # reads at their pace.
    printf '    %s\n' "$description"
    printf '    Recommended default: %s\n' "$default"
    printf '    Risk level: %s   Model when auto: %s\n' "$risk" "$model"

    local choice=""
    while [ -z "$choice" ]; do
      printf '    Handle as [a]uto / [f]ix-default / [s]ask? [a/f/s]: '
      read -r choice
      case "$choice" in
        a|A|auto)        choice="auto" ;;
        f|F|fix|fix-default) choice="$default" ;;
        s|S|ask)         choice="ask" ;;
        *)               choice="" ;;
      esac
    done

    # Update .atelier.json. We use jq to merge in the new entry; atomic
    # via temp file. "ask" is the template default so we omit it to keep
    # the file small.
    if [ "$choice" != "ask" ]; then
      local tmp
      tmp="$(mktemp)"
      jq --arg c "$category" --arg v "$choice" \
        '.decisionPolicy.byCategory[$c] = $v' \
        "$target" > "$tmp" \
        && mv "$tmp" "$target" \
        || { rm -f "$tmp"; die "failed to write $target while updating policy for $category"; }
    fi
    sublog "  → $category: $choice"
  done < <(jq -r '.categories | keys[]' "$catalog")

  POLICY_STATUS="configured"
}

# ---------- step 4: ROADMAP.md / IN_PROGRESS.md / HISTORY.md ----------
step_roadmap_files() {
  if [ ! -f "$PROJECT/ROADMAP.md" ]; then
    cat > "$PROJECT/ROADMAP.md" <<EOF
# Roadmap — $PROJECT_NAME

Backlog of work for this project. Tasks flow: \`ROADMAP.md\` → \`IN_PROGRESS.md\` → \`HISTORY.md\`.

Format per item: \`- [ ] <type> <title> [#id] [~estimate] [blocked_by:...]\` (PLAN.md §5).

## 🔥 P0 — Blockers

(Non-negotiable items. Keep this list small — anything here blocks shipping.)

## 🎯 P1 — Next

## 💭 P2 — Backlog
EOF
    ROADMAP_STATUS="created"
  else
    ROADMAP_STATUS="preserved"
  fi

  if [ ! -f "$PROJECT/IN_PROGRESS.md" ]; then
    cat > "$PROJECT/IN_PROGRESS.md" <<EOF
# In Progress

Active tasks for the current development cycle.

Workflow: \`ROADMAP.md\` → start a task → move here → finish → move to \`HISTORY.md\`.

When a PR closes a task, the **same PR** must update both \`IN_PROGRESS.md\` (remove) and \`HISTORY.md\` (add). Do not defer either to a follow-up commit on the protected branch after merge.
EOF
    INPROGRESS_STATUS="created"
  else
    INPROGRESS_STATUS="preserved"
  fi

  if [ ! -f "$PROJECT/HISTORY.md" ]; then
    cat > "$PROJECT/HISTORY.md" <<EOF
# History

Completed work log. Newest first. Each entry references the PR(s) that delivered the work.
EOF
    HISTORY_STATUS="created"
  else
    HISTORY_STATUS="preserved"
  fi
}

# ---------- step 5: .claude/CLAUDE.md ----------
step_project_claude_md() {
  local target="$PROJECT/.claude/CLAUDE.md"
  # Same convention as step_settings_json — read from atelier's config dir,
  # not $CLAUDE_PLUGIN_ROOT. project-claude.md.template has no install-time
  # placeholder (only <project-name> at runtime) but install.sh copies it
  # into $ATELIER_CONFIG_DIR/templates/ alongside the instantiated
  # settings.template.json for source-path consistency.
  local template="$ATELIER_CONFIG_DIR/templates/project-claude.md.template"

  [ -f "$template" ] || die "template missing: $template"

  if [ -f "$target" ]; then
    CLAUDE_STATUS="preserved"
    return
  fi

  mkdir -p "$PROJECT/.claude"
  sed "s|<project-name>|$PROJECT_NAME|g" "$template" > "$target"
  CLAUDE_STATUS="created"
}

# ---------- step 6: .npmrc ----------
step_npmrc() {
  local target="$PROJECT/.npmrc"
  local needed=("ignore-scripts=true" "minimum-release-age=10080" "audit-level=moderate")

  if [ ! -f "$target" ]; then
    {
      echo "# atelier supply-chain guardrails (PLAN.md §4) — managed by /setup-project"
      printf '%s\n' "${needed[@]}"
    } > "$target"
    NPMRC_STATUS="created"
    return
  fi

  local missing=() line
  for line in "${needed[@]}"; do
    grep -qxF "$line" "$target" || missing+=("$line")
  done

  if [ ${#missing[@]} -eq 0 ]; then
    NPMRC_STATUS="preserved"
    return
  fi

  {
    echo ""
    echo "# atelier supply-chain guardrails (PLAN.md §4) — appended by /setup-project"
    printf '%s\n' "${missing[@]}"
  } >> "$target"
  NPMRC_STATUS="appended"
}

# ---------- step 7: .gitignore ----------
step_gitignore() {
  local target="$PROJECT/.gitignore"
  # `.claude/settings.json` is per-operator: the helper substitutes <worktree>
  # with the operator's absolute path, so committing it would propagate that
  # path to every clone (HISTORY → dogfood-3, Finding D3-3). Gitignore it.
  local needed=(".task-log/" ".claude/settings.json" ".claude/settings.local.json" ".DS_Store")

  if [ ! -f "$target" ]; then
    printf '%s\n' "${needed[@]}" > "$target"
    GITIGNORE_STATUS="created"
    return
  fi

  local missing=() line
  for line in "${needed[@]}"; do
    grep -qxF "$line" "$target" || missing+=("$line")
  done

  if [ ${#missing[@]} -eq 0 ]; then
    GITIGNORE_STATUS="preserved"
    return
  fi

  {
    echo ""
    echo "# atelier — appended by /setup-project"
    printf '%s\n' "${missing[@]}"
  } >> "$target"
  GITIGNORE_STATUS="appended"
}

# ---------- step 8: record setup in $ATELIER_CONFIG_DIR/projects.json ----------
step_record_setup() {
  local now plugin_version name tmp
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  plugin_version="$(jq -r '.version // "unknown"' "$PLUGIN_ROOT/.claude-plugin/plugin.json")"
  # M5.1: persist a human-friendly `name` (basename of the project path)
  # alongside setupCompleted + setupVersion. Consumed by the M5.3 picker
  # so the operator sees the project's short name in the list, not just
  # the absolute path.
  name="$(basename "$PROJECT")"

  mkdir -p "$(dirname "$CONFIG_FILE")"

  tmp="$(mktemp)"
  if [ -f "$CONFIG_FILE" ]; then
    jq --arg path "$PROJECT" --arg ts "$now" --arg ver "$plugin_version" --arg name "$name" \
      '.projects[$path] = {name: $name, setupCompleted: $ts, setupVersion: $ver}' \
      "$CONFIG_FILE" > "$tmp" \
      || { rm -f "$tmp"; die "failed to merge $CONFIG_FILE — refusing to overwrite"; }
    CONFIG_STATUS="updated"
  else
    jq -n --arg path "$PROJECT" --arg ts "$now" --arg ver "$plugin_version" --arg name "$name" \
      '{projects: {($path): {name: $name, setupCompleted: $ts, setupVersion: $ver}}}' > "$tmp" \
      || { rm -f "$tmp"; die "failed to create $CONFIG_FILE"; }
    CONFIG_STATUS="created"
  fi
  mv "$tmp" "$CONFIG_FILE"

  SETUP_COMPLETED="$now"
  SETUP_VERSION="$plugin_version"
}

# ---------- M7.1.F56: reviewer access to this repo ----------
# The independent reviewer agent runs under a SEPARATE GitHub identity
# ($ATELIER_CONFIG_DIR/gh/reviewer). On a freshly-created PRIVATE repo it
# is not a collaborator, so the auto-merge review step fails with "Could
# not resolve to a Repository" and the gate stalls silently. Detect this
# at onboarding and, when the operator is the repo admin, offer to grant
# the reviewer read access (and accept the invitation) so the review path
# works from the first task. Read-only / advisory otherwise — never fails
# the setup.
step_reviewer_access() {
  REVIEWER_ACCESS_STATUS="skipped"
  local reviewer_dir="$ATELIER_CONFIG_DIR/gh/reviewer"
  local author_dir="$ATELIER_CONFIG_DIR/gh/author"

  command -v gh >/dev/null 2>&1 \
    || { REVIEWER_ACCESS_STATUS="skipped (gh not on PATH)"; return 0; }
  git -C "$PROJECT" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || { REVIEWER_ACCESS_STATUS="skipped (not a git repo)"; return 0; }
  [ -d "$reviewer_dir" ] \
    || { REVIEWER_ACCESS_STATUS="skipped (reviewer identity not configured)"; return 0; }

  local owner_repo
  owner_repo="$( (cd "$PROJECT" && env GH_CONFIG_DIR="$author_dir" gh repo view --json nameWithOwner --jq .nameWithOwner) 2>/dev/null || true)"
  [ -n "$owner_repo" ] \
    || { REVIEWER_ACCESS_STATUS="skipped (no GitHub remote)"; return 0; }

  # Already accessible? Nothing to do.
  if ( cd "$PROJECT" && env GH_CONFIG_DIR="$reviewer_dir" gh repo view "$owner_repo" --json nameWithOwner ) >/dev/null 2>&1; then
    REVIEWER_ACCESS_STATUS="ok ($owner_repo visible to reviewer)"
    return 0
  fi

  local reviewer_login
  reviewer_login="$(env GH_CONFIG_DIR="$reviewer_dir" gh api user --jq .login 2>/dev/null || true)"

  # Granting access requires the author to be an admin on the repo.
  local perm
  perm="$( (cd "$PROJECT" && env GH_CONFIG_DIR="$author_dir" gh repo view --json viewerPermission --jq .viewerPermission) 2>/dev/null || true)"

  if [ "$perm" != "ADMIN" ]; then
    warn "Reviewer ${reviewer_login:-<reviewer>} cannot access $owner_repo and you are not its admin (permission: ${perm:-unknown})."
    warn "Auto-merge review will fail until the reviewer is granted read access — ask the repo admin to add it as a collaborator."
    REVIEWER_ACCESS_STATUS="needs access (not admin — cannot grant)"
    return 0
  fi

  if $NONINTERACTIVE; then
    warn "Reviewer ${reviewer_login:-<reviewer>} cannot access $owner_repo; not granting in non-interactive mode."
    warn "Grant manually: env GH_CONFIG_DIR=\"$author_dir\" gh api -X PUT repos/$owner_repo/collaborators/${reviewer_login:-<login>} -f permission=pull"
    REVIEWER_ACCESS_STATUS="needs access (non-interactive — not granted)"
    return 0
  fi

  printf "Reviewer '%s' cannot access %s. Add it as a read collaborator now? [y/N]: " "${reviewer_login:-<reviewer>}" "$owner_repo" >&2
  local ans; read -r ans
  case "$ans" in
    y|Y|yes|Yes) ;;
    *) REVIEWER_ACCESS_STATUS="declined (reviewer still lacks access)"; return 0 ;;
  esac

  if [ -z "$reviewer_login" ]; then
    warn "Could not resolve the reviewer GitHub login; cannot grant access."
    REVIEWER_ACCESS_STATUS="failed (reviewer login unknown)"
    return 0
  fi

  if ! ( cd "$PROJECT" && env GH_CONFIG_DIR="$author_dir" gh api -X PUT "repos/$owner_repo/collaborators/$reviewer_login" -f permission=pull ) >/dev/null 2>&1; then
    warn "Failed to add $reviewer_login as a collaborator on $owner_repo (admin rights required)."
    REVIEWER_ACCESS_STATUS="failed (could not add collaborator)"
    return 0
  fi
  sublog "invited $reviewer_login to $owner_repo (read)"

  # Private repos require the invitee to ACCEPT before access is effective.
  local inv_id
  inv_id="$(env GH_CONFIG_DIR="$reviewer_dir" gh api user/repository_invitations --jq ".[] | select(.repository.full_name==\"$owner_repo\") | .id" 2>/dev/null | head -1 || true)"
  if [ -n "$inv_id" ]; then
    if env GH_CONFIG_DIR="$reviewer_dir" gh api -X PATCH "user/repository_invitations/$inv_id" >/dev/null 2>&1; then
      sublog "reviewer accepted the invitation"
    else
      warn "Reviewer could not auto-accept invitation $inv_id — accept it manually under the reviewer identity."
    fi
  fi

  # Re-verify so the summary reflects the real end state.
  if ( cd "$PROJECT" && env GH_CONFIG_DIR="$reviewer_dir" gh repo view "$owner_repo" --json nameWithOwner ) >/dev/null 2>&1; then
    REVIEWER_ACCESS_STATUS="granted ($reviewer_login now has read access)"
  else
    REVIEWER_ACCESS_STATUS="invited (reviewer must accept the invitation)"
  fi
  return 0
}

# ---------- per-task mode: only write <worktree>/.claude/settings.json ----------
# Invoked by /next-task step 7. Runs outside the harness's permission scope
# (the harness only gates the `Bash(atelier-setup-project ...)` invocation
# itself; the subprocess can write to .claude/** freely). See HISTORY M4.11
# for the harness behavior that motivated this path; M4.16 introduces it.
step_per_task_settings() {
  local target="$PROJECT/.claude/settings.json"
  local template="$ATELIER_CONFIG_DIR/templates/settings.template.json"

  [ -f "$template" ] \
    || die "template missing: $template (run install.sh first to instantiate the template into \$ATELIER_CONFIG_DIR/templates/)"

  mkdir -p "$PROJECT/.claude"

  local tmp; tmp="$(mktemp)"
  sed "s|<worktree>|$PROJECT|g" "$template" > "$tmp" \
    || { rm -f "$tmp"; die "sed substitution failed for $target"; }

  jq empty "$tmp" >/dev/null 2>&1 \
    || { rm -f "$tmp"; die "$template did not produce valid JSON after substitution"; }

  if grep -q "<worktree>" "$tmp"; then
    rm -f "$tmp"
    die "$template still contains literal '<worktree>' after substitution — template bug"
  fi
  if grep -q "<atelier-config-dir>" "$tmp"; then
    rm -f "$tmp"
    die "$template still contains literal '<atelier-config-dir>' — install.sh did not instantiate the template under \$ATELIER_CONFIG_DIR/templates/ (re-run install.sh)"
  fi

  local first_slot
  first_slot="$(jq -r '.permissions.additionalDirectories[0]' "$tmp" 2>/dev/null)" \
    || { rm -f "$tmp"; die "could not read .permissions.additionalDirectories[0] from instantiated settings"; }
  if [ "$first_slot" != "$PROJECT" ]; then
    rm -f "$tmp"
    die "substituted <worktree> did not land in canonical first slot of additionalDirectories (got '$first_slot', expected '$PROJECT')"
  fi

  mv "$tmp" "$target"
  SETTINGS_STATUS="created"
}

run_per_task_mode() {
  case "$PER_TASK_SETTINGS_PATH" in
    /*) ;;
    *) die "--per-task-settings requires an absolute path, got '$PER_TASK_SETTINGS_PATH'" ;;
  esac
  [ -d "$PER_TASK_SETTINGS_PATH" ] \
    || die "--per-task-settings path does not exist or is not a directory: $PER_TASK_SETTINGS_PATH"

  PLUGIN_ROOT="$(resolve_plugin_root)"
  PROJECT="$PER_TASK_SETTINGS_PATH"

  log "atelier-setup-project ${VERSION} --per-task-settings"
  sublog "plugin-root: $PLUGIN_ROOT"
  sublog "worktree:    $PROJECT"

  step_per_task_settings

  echo ""
  ok "per-task settings $SETTINGS_STATUS: $PROJECT/.claude/settings.json"
}

# ---------- main flow ----------
if [ -n "$PER_TASK_SETTINGS_PATH" ]; then
  run_per_task_mode
  exit 0
fi

PLUGIN_ROOT="$(resolve_plugin_root)"
PROJECT="$(resolve_project_path)"
PROJECT_NAME="$(basename "$PROJECT")"

log "atelier-setup-project ${VERSION}"
sublog "plugin-root: $PLUGIN_ROOT"
sublog "project:     $PROJECT"

RECONFIGURE=false
if is_configured "$PROJECT"; then
  completed="$(jq -r --arg p "$PROJECT" '.projects[$p].setupCompleted // "unknown"' "$CONFIG_FILE")"
  version="$(jq -r --arg p "$PROJECT" '.projects[$p].setupVersion // "unknown"' "$CONFIG_FILE")"

  if $NONINTERACTIVE; then
    warn "$PROJECT is already configured (since $completed, version $version)."
    warn "Reconfigure is not allowed in non-interactive mode because it overwrites"
    warn ".claude/settings.json with the current plugin template. Re-run interactively"
    warn "(without --yes / ATELIER_AUTO) if you genuinely want to reconfigure."
    exit 2
  fi

  printf "Project already configured (since %s, version %s). Re-run setup? [y/N]: " "$completed" "$version" >&2
  read -r ans
  case "$ans" in
    y|Y|yes|Yes) RECONFIGURE=true; sublog "operator confirmed reconfigure" ;;
    *) ok "$PROJECT already configured — nothing to do"; exit 0 ;;
  esac
fi

step_settings_json
step_atelier_config_json
step_decision_policy
step_roadmap_files
step_project_claude_md
step_npmrc
step_gitignore
step_record_setup
step_reviewer_access

# ---------- M4.19: detect project mode + root CLAUDE.md presence ----------
# Detection runs after the mechanical scaffolding. Drafting the root
# CLAUDE.md (AI work) is the /setup-project slash command's job —
# this bash binary only emits the signals.
DETECTED_MODE="$(detect_project_mode "$PROJECT")"
ROOT_CLAUDE_MD_STATUS="$(detect_root_claude_md "$PROJECT")"
TRACKING_LAYOUT_STATUS="$(detect_tracking_layout)"

# ---------- output ----------
echo ""
ok "$PROJECT set up for atelier"
sublog ".claude/settings.json:          $SETTINGS_STATUS"
sublog ".atelier.json:                  $ATELIER_CONFIG_STATUS"
sublog "decision policy:                $POLICY_STATUS"
sublog "ROADMAP.md:                     $ROADMAP_STATUS"
sublog "IN_PROGRESS.md:                 $INPROGRESS_STATUS"
sublog "tracking layout:                $TRACKING_LAYOUT_STATUS"
sublog "HISTORY.md:                     $HISTORY_STATUS"
sublog ".claude/CLAUDE.md:              $CLAUDE_STATUS"
sublog ".npmrc:                         $NPMRC_STATUS"
sublog ".gitignore:                     $GITIGNORE_STATUS"
sublog "reviewer repo access:           $REVIEWER_ACCESS_STATUS"
sublog "$(printf '%s' "$CONFIG_FILE" | sed "s|^$HOME|~|"): $CONFIG_STATUS"
sublog "setupCompleted:                 $SETUP_COMPLETED"
sublog "setupVersion:                   $SETUP_VERSION"
echo ""
# M4.19: structured marker lines the /setup-project slash command parses
# to decide whether to dispatch project-profiler (and in which mode).
# Format is `key=value` so the slash command can do a simple grep.
printf 'atelier-detected-mode=%s\n' "$DETECTED_MODE"
printf 'atelier-root-claude-md=%s\n' "$ROOT_CLAUDE_MD_STATUS"
printf 'atelier-tracking-layout=%s\n' "$TRACKING_LAYOUT_STATUS"
echo ""
if [ "$ROOT_CLAUDE_MD_STATUS" = "missing" ]; then
  sublog "Root CLAUDE.md is missing. The /setup-project slash command will dispatch"
  sublog "the project-profiler agent in '$DETECTED_MODE' mode to draft it."
else
  sublog "Root CLAUDE.md already present — preserved."
fi
if [ "$TRACKING_LAYOUT_STATUS" = "preserved-nonempty" ]; then
  echo ""
  sublog "IN_PROGRESS.md pre-existed and carries task-like content. The /setup-project"
  sublog "slash command will check whether it is a legacy multi-phase tracker and, if so,"
  sublog "offer to normalize it with /adopt-roadmap (claude-roadmap-tools)."
fi
echo ""
sublog "Next: cd $PROJECT && run /atelier:next-task to claim the first ROADMAP.md item."
